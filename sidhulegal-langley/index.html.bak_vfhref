if(_ST['es'])_ST['es']['pc_desc_fl']='Divorcio, custodia de hijos, manutención conyugal y división de bienes. Brindamos representación compasiva y orientada a resultados para familias de {city}.';
var _orig=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _orig(lang);
  var T=_ST[lang]||_ST.en;

  // Additional section labels
  document.querySelectorAll('.section-label').forEach(function(el){
    var k=LABEL_MAP[el.textContent.trim().toLowerCase()];
    if(k&&T[k]) el.textContent=T[k];
  });

  // Section title: only "How It Works" (generic across sites)
  document.querySelectorAll('.section-title').forEach(function(el){
    var k=TITLE_MAP[el.textContent.trim().toLowerCase()];
    if(k&&T[k]) el.textContent=T[k];
  });

  // Practice area at-tags
  document.querySelectorAll('.at-tag').forEach(function(el){
    var k=PA_MAP[el.textContent.trim().toLowerCase()];
    if(k&&T[k]) el.textContent=T[k];
  });

  // Practice card titles (h3 inside .practice-card-body, .strip-title)
  document.querySelectorAll('.practice-card-title,.strip-title').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent.trim();
    var k=el.dataset.pakey||PA_MAP[(el.dataset.orig||el.textContent).trim().toLowerCase()];
    if(k){if(!el.dataset.pakey)el.dataset.pakey=k;if(T[k])el.textContent=T[k];else if(lang==='en')el.textContent=el.dataset.orig;}
  });


  // Practice card titles + descriptions (data-pc / data-pd)
  var T2=_ST[lang]||_ST.en;
  document.querySelectorAll('[data-pc]').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    var val=T2[el.dataset.pc];
    el.textContent=val||(lang==='en'?el.dataset.orig:el.textContent);
  });
  document.querySelectorAll('[data-pd]').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    var val=T2[el.dataset.pd];
    el.textContent=val||(lang==='en'?el.dataset.orig:el.textContent);
  });

  // Form select options (skip blank placeholder)
  document.querySelectorAll('select[name="case_type"] option').forEach(function(opt){
    if(!opt.value&&opt.value!==0) return;
    var k=OPT_MAP[opt.textContent.trim().toLowerCase()];
    if(k&&T[k]) opt.textContent=T[k];
  });
};

// Re-apply if a language is already saved
var saved=localStorage.getItem('sidhu_lang');
if(saved&&saved!=='en'&&_ST[saved]) window.sidhuSetLang(saved);
})();

if(_ST['pa'])_ST['pa']['awards_title_bc']='ਭਰੋਸੇਮੰਦ। ਮਾਨਤਾ ਪ੍ਰਾਪਤ। ਨਤੀਜੇ-ਆਧਾਰਿਤ।';
if(_ST['pa'])_ST['pa']['practice_intro_sub']='ICBC ਵਿਵਾਦਾਂ ਤੋਂ ਪਰਿਵਾਰਕ ਕਾਨੂਨ ਤੱਕ, ਅਸੀਂ {city} ਦੇ ਨਿਵਾਸੀਆਂ ਲਈ ਸਭੇ ਪ੍ਰਕਾਰ ਦੇ ਕੇਸ ਸੰਭਾਲਦੇ ਹਾਂ।';
if(_ST['pa'])_ST['pa']['why_section_intro']='ਜ਼ਿਆਦਾਤਰ ਬੀਮਾ ਕੰਪਨੀਆਂ ਭਰੋਸਾ ਕਰਦੀਆਂ ਹਨ ਕਿ ਤੁਹਾਨੂੰ ਆਪਣੇ ਹੱਕਾਂ ਦਾ ਪਤਾ ਨਹੀਂ। ਅਸੀਂ ਯਕੀਨੀ ਕਰਦੇ ਹਾਂ ਕਿ ਉਹ ਤੁਹਾਡਾ ਫਾਇਦਾ ਨਹੀਂ ਉਠਾ ਸਕਦੇ।';
if(_ST['pa'])_ST['pa']['why_t1_full']='ਜੇ ਜਿੱਤੇ ਤਾਂ ਹੀ ਫੀਸ';
if(_ST['pa'])_ST['pa']['why_d1_full']='ਅਸੀਂ ਕਨਟਿੰਜੈਂਸੀ ਅਧਾਰ ਤੇ ਕੰਮ ਕਰਦੇ ਹਾਂ। ਤੁਸੀਂ ਪਹਿਲਾਂ ਕੁਝ ਨਹੀਂ ਦਿੰਦੇ ਅਤੇ ਜੇ ਕੇਸ ਨਹੀਂ ਜਿੱਤਦੇ ਤਾਂ ਕੁਝ ਨਹੀਂ ਦੇਣਾ।';
if(_ST['pa'])_ST['pa']['why_direct_access']='ਆਪਣੇ ਵਕੀਲ ਤੱਕ ਸਿੱਧੀ ਪਹੁੰਚ';
if(_ST['pa'])_ST['pa']['why_direct_desc']='ਤੁਸੀਂ ਸਿੱਧੇ ਸ਼ੌਨ ਨਾਲ ਗੱਲ ਕਰਦੇ ਹੋ। ਕੋਈ ਪੈਰਾਲੀਗਲ ਨਹੀਂ, ਕੋਈ ਰਿਸੈਪਸ਼ਨਿਸਟ ਨਹੀਂ। ਹਰ ਕਦਮ ਤੇ ਪਾਰਦਰਸ਼ੀ ਅੱਪਡੇਟ।';
if(_ST['pa'])_ST['pa']['why_speak_lang']='ਅਸੀਂ ਤੁਹਾਡੀ ਭਾਸ਼ਾ ਬੋਲਦੇ ਹਾਂ';
