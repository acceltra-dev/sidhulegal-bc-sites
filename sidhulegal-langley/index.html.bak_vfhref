if(_ST['hi'])_ST['hi']['why_sub']='बीमा कंपनियां आपके अधिकारों के बारे में आपकी अज्ञानता पर निर्भर करती हैं। हम यह सुनिश्चित करते हैं कि वे आपका फायदा नहीं उठा सकतीं।';
