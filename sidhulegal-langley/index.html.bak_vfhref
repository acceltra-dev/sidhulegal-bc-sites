if(_ST['es'])_ST['es']['pc_med']='Negligencia médica';
if(_ST['es'])_ST['es']['pd_car']='Luchamos contra las compañías de seguros para que usted reciba la indemnización completa que merece, no lo que ellos quieren pagar.';
if(_ST['es'])_ST['es']['pd_brain']='Las lesiones graves requieren representación seria. Buscamos la máxima compensación por lesiones cerebrales, de columna y otros daños catastróficos.';
if(_ST['es'])_ST['es']['pd_slip']='Los propietarios tienen la obligación legal de mantener sus instalaciones seguras. Si la negligencia causó su caída, puede tener derecho a una compensación significativa.';
if(_ST['es'])_ST['es']['pd_moto']='Los motociclistas enfrentan riesgos únicos y prejuicios de los aseguradores. Nivelamos el campo de juego y buscamos cada dólar de compensación disponible.';
if(_ST['es'])_ST['es']['pd_death']='Si ha perdido un ser querido por negligencia ajena, buscamos compensación completa en nombre de su familia con compasión y determinación.';
if(_ST['es'])_ST['es']['pd_ltd']='Las compañías de seguros suelen negar reclamos legítimos de incapacidad. Impugnamos esas decisiones y luchamos por los beneficios que usted pagó.';
if(_ST['es'])_ST['es']['pd_ped']='Los peatones atropellados enfrentan lesiones graves. Luchamos por compensación completa incluyendo gastos médicos, pérdida de ingresos y atención a largo plazo.';
if(_ST['es'])_ST['es']['pd_bike']='Los ciclistas son los usuarios más vulnerables de la vía. Si fue golpeado por un vehículo, merece la máxima compensación por sus lesiones.';
if(_ST['es'])_ST['es']['pd_dog']='Los dueños de animales son responsables por las lesiones que causan sus mascotas. Las víctimas de quemaduras también tienen reclamos sólidos. Buscamos compensación completa por lesiones físicas, cicatrices y trauma.';
if(_ST['es'])_ST['es']['pd_ride']='¿Lesionado en un Uber o Lyft? La cobertura de seguros en casos de transporte compartido es compleja. Nosotros la manejamos por usted.';
if(_ST['es'])_ST['es']['pd_product']='Los productos defectuosos que causan lesiones crean responsabilidad del fabricante. Hacemos que las empresas rindan cuentas cuando sus productos le dañan.';
if(_ST['es'])_ST['es']['pd_med']='Cuando los proveedores de atención médica fallan en su deber de cuidado, las consecuencias pueden ser devastadoras. Luchamos por las víctimas de negligencia médica.';

