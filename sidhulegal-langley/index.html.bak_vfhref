<script>
/* GA4 lead/conversion tracking */
document.addEventListener('DOMContentLoaded',function(){
  function ev(name,label){ if(typeof gtag==='function'){ gtag('event',name,{event_category:'lead',event_label:label}); } }
  document.querySelectorAll('a[href^="tel:"]').forEach(function(a){ a.addEventListener('click',function(){ ev('phone_call','click_to_call'); }); });
  document.querySelectorAll('a[href*="wa.me"]').forEach(function(a){ a.addEventListener('click',function(){ ev('whatsapp_click','whatsapp'); }); });
  document.querySelectorAll('form').forEach(function(f){ f.addEventListener('submit',function(){ ev('generate_lead','contact_form'); }); });
});
