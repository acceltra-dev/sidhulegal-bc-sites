<script id="hero-cost-i18n">
(function(){
  if(typeof window.sidhuSetLang!=='function')return;
  var TXT={
    en:['$0 upfront cost.','You pay nothing unless we win your case.'],
    fr:['0 $ de frais initiaux.','Vous ne payez rien sauf si nous gagnons votre dossier.'],
    pa:['$0 ਪੇਸ਼ਗੀ ਖਰਚਾ।','ਜਦੋਂ ਤੱਕ ਅਸੀਂ ਤੁਹਾਡਾ ਕੇਸ ਨਹੀਂ ਜਿੱਤਦੇ, ਤੁਸੀਂ ਕੁਝ ਨਹੀਂ ਦਿੰਦੇ।'],
    zh:['$0 预付费用。','除非我们赢得您的案件，否则您无需支付任何费用。'],
    hi:['$0 अग्रिम लागत।','जब तक हम आपका केस नहीं जीतते, तब तक आप कुछ नहीं देते।'],
    es:['$0 de costo inicial.','No paga nada a menos que ganemos su caso.']
  };
  function applyBadge(lang){
    var t=TXT[lang]||TXT.en;
    document.querySelectorAll('.hero-cost-badge, .hero-cost').forEach(function(b){
      var span=b.querySelector('span'); if(!span)return;
      var strong=span.querySelector('strong'); if(strong)strong.textContent=t[0];
      var node=strong?strong.nextSibling:span.firstChild;
      while(node&&node.nodeType!==3)node=node.nextSibling;
      if(node)node.nodeValue=' '+t[1]; else span.insertAdjacentText('beforeend',' '+t[1]);
    });
  }
  var _o=window.sidhuSetLang;
  window.sidhuSetLang=function(lang){ _o(lang); applyBadge(lang); };
  var sv=localStorage.getItem('sidhu_lang');
  if(sv&&_o&&TXT[sv])applyBadge(sv);
})();
</script><script>
/* Estimate modal translations */
if(_ST['fr']){_ST['fr']['em_eyebrow']='Presque terminé';_ST['fr']['em_title']='Obtenons votre vraie estimation';_ST['fr']['em_body']='La fourchette ci-dessus n\'est qu\'une illustration approximative. La vraie valeur de votre réclamation dépend de détails que seul Shawn peut évaluer, et la consultation est gratuite. Voici le moyen le plus rapide d\'obtenir votre vrai chiffre.';_ST['fr']['em_callsub']='Le moyen le plus rapide d\'obtenir des réponses. Gratuit et confidentiel.';_ST['fr']['em_formbtn']='Vous préférez l\'écrire? Remplissez le formulaire rapide →';_ST['fr']['em_handy']='Ayez ceci à portée de main pour accélérer';_ST['fr']['em_li1']='• Votre numéro de réclamation ICBC (si vous en avez un)';_ST['fr']['em_li2']='• La date et le lieu de l\'accident';_ST['fr']['em_li3']='• Tout dossier médical, photo ou reçu';}
if(_ST['pa']){_ST['pa']['em_eyebrow']='ਲਗਭਗ ਹੋ ਗਿਆ';_ST['pa']['em_title']='ਆਓ ਤੁਹਾਡਾ ਅਸਲ ਅੰਦਾਜ਼ਾ ਲਈਏ';_ST['pa']['em_body']='ਉੱਪਰ ਦਿੱਤੀ ਰੇਂਜ ਸਿਰਫ਼ ਇੱਕ ਮੋਟਾ ਅੰਦਾਜ਼ਾ ਹੈ। ਤੁਹਾਡੇ ਦਾਅਵੇ ਦੀ ਅਸਲ ਕੀਮਤ ਉਨ੍ਹਾਂ ਵੇਰਵਿਆਂ \'ਤੇ ਨਿਰਭਰ ਕਰਦੀ ਹੈ ਜਿਨ੍ਹਾਂ ਦਾ ਮੁਲਾਂਕਣ ਸਿਰਫ਼ ਸ਼ਾਨ ਹੀ ਕਰ ਸਕਦਾ ਹੈ, ਅਤੇ ਸਲਾਹ ਮੁਫ਼ਤ ਹੈ। ਆਪਣਾ ਅਸਲ ਅੰਕੜਾ ਪ੍ਰਾਪਤ ਕਰਨ ਦਾ ਸਭ ਤੋਂ ਤੇਜ਼ ਤਰੀਕਾ ਇਹ ਹੈ।';_ST['pa']['em_callsub']='ਜਵਾਬ ਪ੍ਰਾਪਤ ਕਰਨ ਦਾ ਸਭ ਤੋਂ ਤੇਜ਼ ਤਰੀਕਾ। ਮੁਫ਼ਤ ਅਤੇ ਗੁਪਤ।';_ST['pa']['em_formbtn']='ਲਿਖ ਕੇ ਦੱਸਣਾ ਚਾਹੁੰਦੇ ਹੋ? ਤੇਜ਼ ਫਾਰਮ ਭਰੋ →';_ST['pa']['em_handy']='ਪ੍ਰਕਿਰਿਆ ਤੇਜ਼ ਕਰਨ ਲਈ ਇਹ ਤਿਆਰ ਰੱਖੋ';_ST['pa']['em_li1']='• ਤੁਹਾਡਾ ICBC ਦਾਅਵਾ ਨੰਬਰ (ਜੇ ਤੁਹਾਡੇ ਕੋਲ ਹੈ)';_ST['pa']['em_li2']='• ਹਾਦਸੇ ਦੀ ਤਾਰੀਖ ਅਤੇ ਥਾਂ';_ST['pa']['em_li3']='• ਕੋਈ ਵੀ ਮੈਡੀਕਲ ਰਿਕਾਰਡ, ਫੋਟੋਆਂ ਜਾਂ ਰਸੀਦਾਂ';}
if(_ST['hi']){_ST['hi']['em_eyebrow']='लगभग हो गया';_ST['hi']['em_title']='आइए आपका असली अनुमान लगाएं';_ST['hi']['em_body']='ऊपर दी गई सीमा केवल एक मोटा अनुमान है। आपके दावे की असली कीमत उन विवरणों पर निर्भर करती है जिनका आकलन केवल शॉन ही कर सकते हैं, और परामर्श निःशुल्क है। अपना असली आंकड़ा पाने का सबसे तेज़ तरीका यह है।';_ST['hi']['em_callsub']='जवाब पाने का सबसे तेज़ तरीका। निःशुल्क और गोपनीय।';_ST['hi']['em_formbtn']='लिखकर बताना चाहते हैं? त्वरित फॉर्म भरें →';_ST['hi']['em_handy']='प्रक्रिया तेज़ करने के लिए ये तैयार रखें';_ST['hi']['em_li1']='• आपका ICBC दावा नंबर (यदि आपके पास है)';_ST['hi']['em_li2']='• दुर्घटना की तारीख और स्थान';_ST['hi']['em_li3']='• कोई भी मेडिकल रिकॉर्ड, तस्वीरें या रसीदें';}
if(_ST['zh']){_ST['zh']['em_eyebrow']='就快完成';_ST['zh']['em_title']='让我们为您提供真实的估算';_ST['zh']['em_body']='上面的范围只是粗略的示意。您索赔的真实价值取决于只有Shawn才能评估的细节，而且咨询是免费的。这是获得真实数字最快的方式。';_ST['zh']['em_callsub']='获得答案最快的方式。免费且保密。';_ST['zh']['em_formbtn']='想用文字说明？填写快速表格 →';_ST['zh']['em_handy']='准备好这些以加快进程';_ST['zh']['em_li1']='• 您的ICBC索赔编号（如果有）';_ST['zh']['em_li2']='• 事故的日期和地点';_ST['zh']['em_li3']='• 任何医疗记录、照片或收据';}
if(_ST['es']){_ST['es']['em_eyebrow']='Casi listo';_ST['es']['em_title']='Obtengamos su estimación real';_ST['es']['em_body']='El rango anterior es solo una ilustración aproximada. Lo que realmente vale su reclamo depende de detalles que solo Shawn puede evaluar, y la consulta es gratuita. Esta es la forma más rápida de obtener su cifra real.';_ST['es']['em_callsub']='La forma más rápida de obtener respuestas. Gratis y confidencial.';_ST['es']['em_formbtn']='¿Prefiere escribirlo? Complete el formulario rápido →';_ST['es']['em_handy']='Tenga esto a mano para agilizar';_ST['es']['em_li1']='• Su número de reclamo de ICBC (si tiene uno)';_ST['es']['em_li2']='• La fecha y el lugar del accidente';_ST['es']['em_li3']='• Cualquier registro médico, fotos o recibos';}
(function(){var sv=localStorage.getItem('sidhu_lang');if(sv&&sv!=='en'&&typeof sidhuSetLang==='function')sidhuSetLang(sv);})();
</script>
<script>
/* Extended section translations: Local Knowledge, Practice Areas list, Estimate calculator */
(function(){
  window._LX = {
    fr: {
      ex_eyebrow:'Outil gratuit',ex_h2:'Estimez la valeur de votre réclamation',ex_sub:'Répondez à quelques questions rapides pour une illustration approximative et instantanée d\'une fourchette possible de réclamation. En C.-B., les blessures automobiles sont gérées par le système Enhanced Care d\'ICBC, donc les montants réels varient selon chaque cas. Pour une évaluation honnête, parlez gratuitement à Shawn Sidhu.',
      ex_lbl_injury:'Type de blessure',ex_opt1:'Tissus mous / coup du lapin',ex_opt2:'Fractures / os cassés',ex_opt3:'Douleur chronique ou lésion nerveuse',ex_opt4:'Blessures graves ou multiples',ex_opt5:'Lésion cérébrale ou médullaire',ex_opt6:'Catastrophique (paralysie, amputation, brûlures)',ex_opt7:'Décès par négligence',ex_opt8:'Autre ou incertain',
      ex_lbl_sev:'Gravité',ex_minor:'Mineure',ex_moderate:'Modérée',ex_severe:'Grave',ex_lbl_weeks:'Semaines d\'incapacité de travail',ex_lbl_wage:'Votre revenu hebdomadaire ($)',
      ex_rlabel1:'Fourchette potentielle estimée',ex_rlabel2:'Touchez un champ pour mettre à jour',ex_uniq1:'Votre cas est unique',ex_uniq2:'Parlons-en',ex_callmsg:'Un cas comme le vôtre mérite une vraie réponse, pas un calculateur. Appelez-nous pour une estimation gratuite et honnête de la valeur de votre réclamation.',
      ex_disc:'Ceci n\'est qu\'une illustration approximative et <b>non</b> un avis juridique, une garantie ou une prédiction d\'une prestation ou d\'un règlement d\'ICBC. La meilleure façon de connaître la vraie valeur de votre réclamation est une évaluation gratuite et sans obligation.',ex_cta:'Obtenir ma vraie estimation →',ex_callbtn:'☎ Appeler (604) 907-3632',
      cx_eyb:'Domaines de pratique',cx_h2:'Blessures et réclamations ICBC que nous traitons',cx_sub:'Des réclamations ICBC aux blessures catastrophiques, Sidhu Legal représente des clients de la C.-B. dans toute la gamme des réclamations pour blessures et accidents. Vous ne voyez pas la vôtre? Demandez-nous, l\'évaluation est gratuite.',
      cx_1:'Réclamations ICBC',cx_2:'Accidents de voiture',cx_3:'Accidents de moto',cx_4:'Accidents de piéton',cx_5:'Blessures de cyclistes',cx_6:'Glissades et chutes',cx_7:'Lésion cérébrale',cx_8:'Lésion de la moelle épinière',cx_9:'Blessure catastrophique',cx_10:'Morsures de chien et attaques d\'animaux',cx_11:'Décès par négligence',cx_12:'Invalidité de longue durée',cx_13:'Réclamations en milieu de travail et de responsabilité',cx_14:'Responsabilité du fait des produits',cx_15:'Accidents de covoiturage (Uber et Lyft)',cx_16:'Erreur médicale',
      cx_notsure:'Vous ne savez pas où se situe votre cas? <a href="#consult" style="color:#c9a040;font-weight:700;text-decoration:none;border-bottom:1px solid rgba(201,160,64,.4)">Obtenez une évaluation gratuite →</a>',
      lx_label:'Connaissance locale',lx_h2:'Blessures et réclamations ICBC à Surrey: ce qu\'il faut savoir',lx_intro:'Surrey est l\'une des villes les plus grandes et à la croissance la plus rapide de la C.-B., et ses autoroutes et artères achalandées sont le théâtre de milliers de collisions chaque année. Si vous avez été blessé à Surrey ou dans les environs, voici le contexte local qui façonne votre réclamation.',
      lx_h3a:'Où surviennent les collisions à Surrey',lx_pa:'L\'autoroute 1 (la Transcanadienne), King George Boulevard, Fraser Highway et l\'autoroute 99 supportent la circulation la plus dense de la ville, tandis que le corridor de la 152e Rue et les approches des ponts Pattullo et Port Mann sont des points de collision fréquents. La pluie forte et le brouillard sont des facteurs courants sur les autoroutes.',
      lx_h3b:'ICBC et votre réclamation',lx_pb:'La plupart des blessures automobiles en C.-B. passent par ICBC, dont le système Enhanced Care offre des prestations médicales et salariales sans égard à la faute. Nous nous assurons qu\'ICBC paie la totalité des prestations qui vous sont dues, contestons les refus et les offres faibles, et poursuivons chaque réclamation supplémentaire que la loi permet encore. En vertu de la Limitation Act de la C.-B., vous avez généralement <strong>2 ans</strong> pour agir.',
      lx_h3c:'Se faire soigner',lx_pc:'Les blessures graves à Surrey sont traitées au Surrey Memorial Hospital, l\'un des centres de traumatologie les plus occupés de la C.-B. Conservez chaque dossier médical et reçu, ils sont essentiels pour prouver votre réclamation.'
    },
    pa: {
      ex_eyebrow:'ਮੁਫ਼ਤ ਟੂਲ',ex_h2:'ਆਪਣੇ ਸੱਟ ਦੇ ਦਾਅਵੇ ਦੀ ਕੀਮਤ ਦਾ ਅੰਦਾਜ਼ਾ ਲਗਾਓ',ex_sub:'ਸੱਟ ਦੇ ਦਾਅਵੇ ਦੀ ਸੰਭਾਵੀ ਰੇਂਜ ਦੇ ਮੋਟੇ, ਤੁਰੰਤ ਅੰਦਾਜ਼ੇ ਲਈ ਕੁਝ ਤੇਜ਼ ਸਵਾਲਾਂ ਦੇ ਜਵਾਬ ਦਿਓ। ਬੀ.ਸੀ. ਵਿੱਚ, ਆਟੋ ਸੱਟਾਂ ICBC ਦੇ Enhanced Care ਸਿਸਟਮ ਰਾਹੀਂ ਸੰਭਾਲੀਆਂ ਜਾਂਦੀਆਂ ਹਨ, ਇਸ ਲਈ ਅਸਲ ਰਕਮਾਂ ਹਰ ਕੇਸ ਮੁਤਾਬਕ ਵੱਖਰੀਆਂ ਹੁੰਦੀਆਂ ਹਨ। ਇਮਾਨਦਾਰ ਮੁਲਾਂਕਣ ਲਈ, ਸ਼ਾਨ ਸਿੱਧੂ ਨਾਲ ਮੁਫ਼ਤ ਗੱਲ ਕਰੋ।',
      ex_lbl_injury:'ਸੱਟ ਦੀ ਕਿਸਮ',ex_opt1:'ਨਰਮ ਟਿਸ਼ੂ / ਵਿਪਲੈਸ਼',ex_opt2:'ਟੁੱਟੀਆਂ ਹੱਡੀਆਂ / ਫ੍ਰੈਕਚਰ',ex_opt3:'ਪੁਰਾਣਾ ਦਰਦ ਜਾਂ ਨਸਾਂ ਦੀ ਸੱਟ',ex_opt4:'ਗੰਭੀਰ ਜਾਂ ਕਈ ਸੱਟਾਂ',ex_opt5:'ਦਿਮਾਗ ਜਾਂ ਰੀੜ੍ਹ ਦੀ ਹੱਡੀ ਦੀ ਸੱਟ',ex_opt6:'ਵਿਨਾਸ਼ਕਾਰੀ (ਅਧਰੰਗ, ਅੰਗ ਕੱਟਣਾ, ਜਲਣ)',ex_opt7:'ਗਲਤ ਮੌਤ',ex_opt8:'ਹੋਰ ਜਾਂ ਯਕੀਨ ਨਹੀਂ',
      ex_lbl_sev:'ਗੰਭੀਰਤਾ',ex_minor:'ਮਾਮੂਲੀ',ex_moderate:'ਦਰਮਿਆਨੀ',ex_severe:'ਗੰਭੀਰ',ex_lbl_weeks:'ਕੰਮ ਨਾ ਕਰ ਸਕਣ ਵਾਲੇ ਹਫ਼ਤੇ',ex_lbl_wage:'ਤੁਹਾਡੀ ਹਫ਼ਤਾਵਾਰ ਆਮਦਨ ($)',
      ex_rlabel1:'ਅੰਦਾਜ਼ਨ ਸੰਭਾਵੀ ਰੇਂਜ',ex_rlabel2:'ਅੱਪਡੇਟ ਕਰਨ ਲਈ ਕਿਸੇ ਖੇਤਰ ਨੂੰ ਛੂਹੋ',ex_uniq1:'ਤੁਹਾਡਾ ਕੇਸ ਵਿਲੱਖਣ ਹੈ',ex_uniq2:'ਆਓ ਗੱਲ ਕਰੀਏ',ex_callmsg:'ਤੁਹਾਡੇ ਵਰਗੇ ਕੇਸ ਨੂੰ ਕੈਲਕੁਲੇਟਰ ਨਹੀਂ, ਅਸਲ ਜਵਾਬ ਚਾਹੀਦਾ ਹੈ। ਆਪਣੇ ਦਾਅਵੇ ਦੀ ਕੀਮਤ ਦੇ ਮੁਫ਼ਤ, ਇਮਾਨਦਾਰ ਅੰਦਾਜ਼ੇ ਲਈ ਸਾਨੂੰ ਕਾਲ ਕਰੋ।',
      ex_disc:'ਇਹ ਸਿਰਫ਼ ਇੱਕ ਮੋਟਾ ਅੰਦਾਜ਼ਾ ਹੈ ਅਤੇ ਕਾਨੂੰਨੀ ਸਲਾਹ, ਗਾਰੰਟੀ, ਜਾਂ ਕਿਸੇ ICBC ਲਾਭ ਜਾਂ ਸਮਝੌਤੇ ਦੀ ਭਵਿੱਖਬਾਣੀ <b>ਨਹੀਂ</b> ਹੈ। ਤੁਹਾਡੇ ਦਾਅਵੇ ਦੀ ਅਸਲ ਕੀਮਤ ਜਾਣਨ ਦਾ ਸਭ ਤੋਂ ਵਧੀਆ ਤਰੀਕਾ ਇੱਕ ਮੁਫ਼ਤ, ਬਿਨਾਂ-ਜ਼ਿੰਮੇਵਾਰੀ ਕੇਸ ਸਮੀਖਿਆ ਹੈ।',ex_cta:'ਮੇਰਾ ਅਸਲ ਅੰਦਾਜ਼ਾ ਲਓ →',ex_callbtn:'☎ ਕਾਲ ਕਰੋ (604) 907-3632',
      cx_eyb:'ਅਭਿਆਸ ਖੇਤਰ',cx_h2:'ਸੱਟ ਅਤੇ ICBC ਕੇਸ ਜੋ ਅਸੀਂ ਸੰਭਾਲਦੇ ਹਾਂ',cx_sub:'ICBC ਦਾਅਵਿਆਂ ਤੋਂ ਲੈ ਕੇ ਵਿਨਾਸ਼ਕਾਰੀ ਸੱਟਾਂ ਤੱਕ, ਸਿੱਧੂ ਲੀਗਲ ਬੀ.ਸੀ. ਦੇ ਗਾਹਕਾਂ ਦੀ ਨਿੱਜੀ ਸੱਟ ਅਤੇ ਹਾਦਸੇ ਦੇ ਦਾਅਵਿਆਂ ਦੀ ਪੂਰੀ ਰੇਂਜ ਵਿੱਚ ਨੁਮਾਇੰਦਗੀ ਕਰਦੀ ਹੈ। ਆਪਣਾ ਨਹੀਂ ਦਿਸਦਾ? ਸਾਨੂੰ ਪੁੱਛੋ, ਕੇਸ ਸਮੀਖਿਆ ਮੁਫ਼ਤ ਹੈ।',
      cx_1:'ICBC ਦਾਅਵੇ',cx_2:'ਕਾਰ ਹਾਦਸੇ ਦੇ ਦਾਅਵੇ',cx_3:'ਮੋਟਰਸਾਈਕਲ ਹਾਦਸੇ',cx_4:'ਪੈਦਲ ਚੱਲਣ ਵਾਲਿਆਂ ਦੇ ਹਾਦਸੇ',cx_5:'ਸਾਈਕਲ ਸਵਾਰਾਂ ਦੀਆਂ ਸੱਟਾਂ',cx_6:'ਤਿਲਕਣਾ ਅਤੇ ਡਿੱਗਣਾ',cx_7:'ਦਿਮਾਗ ਦੀ ਸੱਟ',cx_8:'ਰੀੜ੍ਹ ਦੀ ਹੱਡੀ ਦੀ ਸੱਟ',cx_9:'ਵਿਨਾਸ਼ਕਾਰੀ ਸੱਟ',cx_10:'ਕੁੱਤੇ ਦੇ ਕੱਟਣ ਅਤੇ ਜਾਨਵਰਾਂ ਦੇ ਹਮਲੇ',cx_11:'ਗਲਤ ਮੌਤ',cx_12:'ਲੰਮੇ ਸਮੇਂ ਦੀ ਅਪੰਗਤਾ',cx_13:'ਕੰਮ ਵਾਲੀ ਥਾਂ ਅਤੇ ਜ਼ਿੰਮੇਵਾਰੀ ਦੇ ਦਾਅਵੇ',cx_14:'ਉਤਪਾਦ ਜ਼ਿੰਮੇਵਾਰੀ',cx_15:'ਰਾਈਡਸ਼ੇਅਰ (Uber ਅਤੇ Lyft) ਹਾਦਸੇ',cx_16:'ਮੈਡੀਕਲ ਲਾਪਰਵਾਹੀ',
      cx_notsure:'ਯਕੀਨ ਨਹੀਂ ਕਿ ਤੁਹਾਡਾ ਕੇਸ ਕਿੱਥੇ ਫਿੱਟ ਹੁੰਦਾ ਹੈ? <a href="#consult" style="color:#c9a040;font-weight:700;text-decoration:none;border-bottom:1px solid rgba(201,160,64,.4)">ਮੁਫ਼ਤ ਕੇਸ ਸਮੀਖਿਆ ਲਓ →</a>',
      lx_label:'ਸਥਾਨਕ ਜਾਣਕਾਰੀ',lx_h2:'ਸਰੀ ਵਿੱਚ ਸੱਟ ਅਤੇ ICBC ਦਾਅਵੇ: ਜੋ ਜਾਣਨਾ ਜ਼ਰੂਰੀ ਹੈ',lx_intro:'ਸਰੀ ਬੀ.ਸੀ. ਦੇ ਸਭ ਤੋਂ ਵੱਡੇ ਅਤੇ ਤੇਜ਼ੀ ਨਾਲ ਵਧ ਰਹੇ ਸ਼ਹਿਰਾਂ ਵਿੱਚੋਂ ਇੱਕ ਹੈ, ਅਤੇ ਇਸ ਦੀਆਂ ਹਾਈਵੇਆਂ ਅਤੇ ਰੁੱਝੀਆਂ ਸੜਕਾਂ \'ਤੇ ਹਰ ਸਾਲ ਹਜ਼ਾਰਾਂ ਟੱਕਰਾਂ ਹੁੰਦੀਆਂ ਹਨ। ਜੇ ਤੁਸੀਂ ਸਰੀ ਵਿੱਚ ਜਾਂ ਆਸਪਾਸ ਜ਼ਖਮੀ ਹੋਏ ਹੋ, ਇੱਥੇ ਉਹ ਸਥਾਨਕ ਸੰਦਰਭ ਹੈ ਜੋ ਤੁਹਾਡੇ ਦਾਅਵੇ ਨੂੰ ਘੜਦਾ ਹੈ।',
      lx_h3a:'ਸਰੀ ਵਿੱਚ ਟੱਕਰਾਂ ਕਿੱਥੇ ਹੁੰਦੀਆਂ ਹਨ',lx_pa:'ਹਾਈਵੇ 1 (ਟ੍ਰਾਂਸ-ਕੈਨੇਡਾ), ਕਿੰਗ ਜਾਰਜ ਬੁਲੇਵਾਰਡ, ਫ੍ਰੇਜ਼ਰ ਹਾਈਵੇ, ਅਤੇ ਹਾਈਵੇ 99 ਸ਼ਹਿਰ ਦੀ ਸਭ ਤੋਂ ਵੱਧ ਆਵਾਜਾਈ ਚੁੱਕਦੇ ਹਨ, ਜਦਕਿ 152 ਸਟ੍ਰੀਟ ਕੋਰੀਡੋਰ ਅਤੇ ਪੈਟੁਲੋ ਤੇ ਪੋਰਟ ਮੈਨ ਪੁਲਾਂ ਦੇ ਰਸਤੇ ਅਕਸਰ ਟੱਕਰ ਵਾਲੀਆਂ ਥਾਵਾਂ ਹਨ। ਤੇਜ਼ ਮੀਂਹ ਅਤੇ ਧੁੰਦ ਹਾਈਵੇਆਂ \'ਤੇ ਆਮ ਕਾਰਨ ਹਨ।',
      lx_h3b:'ICBC ਅਤੇ ਤੁਹਾਡਾ ਦਾਅਵਾ',lx_pb:'ਬੀ.ਸੀ. ਦੀਆਂ ਜ਼ਿਆਦਾਤਰ ਆਟੋ ਸੱਟਾਂ ICBC ਰਾਹੀਂ ਚੱਲਦੀਆਂ ਹਨ, ਜਿਸ ਦਾ Enhanced Care ਸਿਸਟਮ ਕਸੂਰ ਦੀ ਪਰਵਾਹ ਕੀਤੇ ਬਿਨਾਂ ਮੈਡੀਕਲ ਅਤੇ ਤਨਖਾਹ ਲਾਭ ਦਿੰਦਾ ਹੈ। ਅਸੀਂ ਯਕੀਨੀ ਬਣਾਉਂਦੇ ਹਾਂ ਕਿ ICBC ਤੁਹਾਨੂੰ ਬਣਦੇ ਪੂਰੇ ਲਾਭ ਅਦਾ ਕਰੇ, ਇਨਕਾਰਾਂ ਅਤੇ ਘੱਟ ਪੇਸ਼ਕਸ਼ਾਂ ਨੂੰ ਚੁਣੌਤੀ ਦਿੰਦੇ ਹਾਂ, ਅਤੇ ਹਰ ਵਾਧੂ ਦਾਅਵਾ ਅੱਗੇ ਵਧਾਉਂਦੇ ਹਾਂ ਜੋ ਕਾਨੂੰਨ ਅਜੇ ਵੀ ਇਜਾਜ਼ਤ ਦਿੰਦਾ ਹੈ। ਬੀ.ਸੀ. ਦੇ Limitation Act ਅਧੀਨ ਤੁਹਾਡੇ ਕੋਲ ਆਮ ਤੌਰ \'ਤੇ ਕਾਰਵਾਈ ਕਰਨ ਲਈ <strong>2 ਸਾਲ</strong> ਹੁੰਦੇ ਹਨ।',
      lx_h3c:'ਇਲਾਜ ਕਰਵਾਉਣਾ',lx_pc:'ਸਰੀ ਵਿੱਚ ਗੰਭੀਰ ਸੱਟਾਂ ਦਾ ਇਲਾਜ ਸਰੀ ਮੈਮੋਰੀਅਲ ਹਸਪਤਾਲ ਵਿੱਚ ਕੀਤਾ ਜਾਂਦਾ ਹੈ, ਜੋ ਬੀ.ਸੀ. ਦੇ ਸਭ ਤੋਂ ਰੁੱਝੇ ਟਰਾਮਾ ਸੈਂਟਰਾਂ ਵਿੱਚੋਂ ਇੱਕ ਹੈ। ਹਰ ਮੈਡੀਕਲ ਰਿਕਾਰਡ ਅਤੇ ਰਸੀਦ ਸੰਭਾਲੋ, ਇਹ ਤੁਹਾਡੇ ਦਾਅਵੇ ਨੂੰ ਸਾਬਤ ਕਰਨ ਲਈ ਕੇਂਦਰੀ ਹਨ।'
    },
    hi: {
      ex_eyebrow:'मुफ़्त टूल',ex_h2:'अपने चोट दावे के मूल्य का अनुमान लगाएं',ex_sub:'चोट दावे की संभावित सीमा के मोटे, तुरंत अनुमान के लिए कुछ त्वरित सवालों के जवाब दें। बीसी में, ऑटो चोटें ICBC की Enhanced Care प्रणाली के माध्यम से संभाली जाती हैं, इसलिए वास्तविक राशि हर मामले के अनुसार अलग होती है। ईमानदार आकलन के लिए, शॉन सिद्धू से मुफ़्त में बात करें।',
      ex_lbl_injury:'चोट का प्रकार',ex_opt1:'नरम ऊतक / व्हिपलैश',ex_opt2:'टूटी हड्डियाँ / फ्रैक्चर',ex_opt3:'पुराना दर्द या तंत्रिका क्षति',ex_opt4:'गंभीर या एकाधिक चोटें',ex_opt5:'मस्तिष्क या रीढ़ की हड्डी की चोट',ex_opt6:'विनाशकारी (पक्षाघात, अंगच्छेदन, जलना)',ex_opt7:'गलत मृत्यु',ex_opt8:'अन्य या निश्चित नहीं',
      ex_lbl_sev:'गंभीरता',ex_minor:'मामूली',ex_moderate:'मध्यम',ex_severe:'गंभीर',ex_lbl_weeks:'काम न कर पाने के सप्ताह',ex_lbl_wage:'आपकी साप्ताहिक आय ($)',
      ex_rlabel1:'अनुमानित संभावित सीमा',ex_rlabel2:'अपडेट करने के लिए किसी फ़ील्ड को छुएं',ex_uniq1:'आपका मामला अनूठा है',ex_uniq2:'आइए बात करें',ex_callmsg:'आपके जैसे मामले को कैलकुलेटर नहीं, असली जवाब चाहिए। अपने दावे के मूल्य के मुफ़्त, ईमानदार अनुमान के लिए हमें कॉल करें।',
      ex_disc:'यह केवल एक मोटा अनुमान है और कानूनी सलाह, गारंटी, या किसी ICBC लाभ या समझौते की भविष्यवाणी <b>नहीं</b> है। आपके दावे का असली मूल्य जानने का सबसे अच्छा तरीका एक मुफ़्त, बिना-बाध्यता केस समीक्षा है।',ex_cta:'मेरा असली अनुमान पाएं →',ex_callbtn:'☎ कॉल करें (604) 907-3632',
      cx_eyb:'अभ्यास क्षेत्र',cx_h2:'चोट और ICBC मामले जो हम संभालते हैं',cx_sub:'ICBC दावों से लेकर विनाशकारी चोटों तक, सिद्धू लीगल बीसी के ग्राहकों का व्यक्तिगत चोट और दुर्घटना दावों की पूरी श्रृंखला में प्रतिनिधित्व करती है। अपना नहीं दिख रहा? हमसे पूछें, केस समीक्षा मुफ़्त है।',
      cx_1:'ICBC दावे',cx_2:'कार दुर्घटना दावे',cx_3:'मोटरसाइकिल दुर्घटनाएं',cx_4:'पैदल यात्री दुर्घटनाएं',cx_5:'साइकिल चालकों की चोटें',cx_6:'फिसलना और गिरना',cx_7:'मस्तिष्क की चोट',cx_8:'रीढ़ की हड्डी की चोट',cx_9:'विनाशकारी चोट',cx_10:'कुत्ते के काटने और जानवरों के हमले',cx_11:'गलत मृत्यु',cx_12:'दीर्घकालिक विकलांगता',cx_13:'कार्यस्थल और दायित्व दावे',cx_14:'उत्पाद दायित्व',cx_15:'राइडशेयर (Uber और Lyft) दुर्घटनाएं',cx_16:'चिकित्सकीय लापरवाही',
      cx_notsure:'निश्चित नहीं कि आपका मामला कहाँ फिट बैठता है? <a href="#consult" style="color:#c9a040;font-weight:700;text-decoration:none;border-bottom:1px solid rgba(201,160,64,.4)">मुफ़्त केस समीक्षा पाएं →</a>',
      lx_label:'स्थानीय जानकारी',lx_h2:'सरी में चोट और ICBC दावे: क्या जानना ज़रूरी है',lx_intro:'सरी बीसी के सबसे बड़े और सबसे तेज़ी से बढ़ते शहरों में से एक है, और इसके हाईवे और व्यस्त सड़कों पर हर साल हज़ारों टक्करें होती हैं। यदि आप सरी में या आसपास घायल हुए हैं, यहाँ वह स्थानीय संदर्भ है जो आपके दावे को आकार देता है।',
      lx_h3a:'सरी में दुर्घटनाएं कहाँ होती हैं',lx_pa:'हाईवे 1 (ट्रांस-कनाडा), किंग जॉर्ज बुलेवार्ड, फ्रेज़र हाईवे, और हाईवे 99 शहर का सबसे भारी यातायात ढोते हैं, जबकि 152 स्ट्रीट कॉरिडोर और पैटुलो तथा पोर्ट मैन पुलों के रास्ते अक्सर टक्कर वाले स्थान हैं। तेज़ बारिश और कोहरा हाईवे पर आम कारक हैं।',
      lx_h3b:'ICBC और आपका दावा',lx_pb:'बीसी की अधिकांश ऑटो चोटें ICBC के माध्यम से चलती हैं, जिसकी Enhanced Care प्रणाली गलती की परवाह किए बिना चिकित्सा और वेतन लाभ देती है। हम सुनिश्चित करते हैं कि ICBC आपको देय पूरे लाभ का भुगतान करे, इनकार और कम पेशकशों को चुनौती दें, और हर अतिरिक्त दावे का पीछा करें जिसकी कानून अभी भी अनुमति देता है। बीसी के Limitation Act के तहत आपके पास आम तौर पर कार्रवाई करने के लिए <strong>2 साल</strong> होते हैं।',
      lx_h3c:'इलाज कराना',lx_pc:'सरी में गंभीर चोटों का इलाज सरी मेमोरियल अस्पताल में किया जाता है, जो बीसी के सबसे व्यस्त ट्रॉमा केंद्रों में से एक है। हर चिकित्सा रिकॉर्ड और रसीद संभालें, ये आपके दावे को साबित करने के लिए केंद्रीय हैं।'
    },
    zh: {
      ex_eyebrow:'免费工具',ex_h2:'估算您的伤害索赔价值',ex_sub:'回答几个简短的问题，即可获得潜在伤害索赔范围的粗略即时示意。在卑诗省，汽车伤害通过 ICBC 的 Enhanced Care 系统处理，因此实际金额因案而异。如需诚实的评估，请免费咨询 Shawn Sidhu。',
      ex_lbl_injury:'伤害类型',ex_opt1:'软组织 / 挥鞭伤',ex_opt2:'骨折 / 骨头断裂',ex_opt3:'慢性疼痛或神经损伤',ex_opt4:'严重或多处伤害',ex_opt5:'脑部或脊髓损伤',ex_opt6:'灾难性（瘫痪、截肢、烧伤）',ex_opt7:'意外死亡',ex_opt8:'其他或不确定',
      ex_lbl_sev:'严重程度',ex_minor:'轻微',ex_moderate:'中等',ex_severe:'严重',ex_lbl_weeks:'无法工作的周数',ex_lbl_wage:'您的周收入（$）',
      ex_rlabel1:'估计潜在范围',ex_rlabel2:'点击字段以更新',ex_uniq1:'您的案件是独特的',ex_uniq2:'让我们谈谈',ex_callmsg:'像您这样的案件需要真实的答案，而不是计算器。请致电我们，免费、诚实地估算您的索赔价值。',
      ex_disc:'这仅为粗略示意，<b>并非</b>法律建议、保证或对任何 ICBC 福利或和解的预测。了解您索赔真实价值的最佳方式是免费、无义务的案件评估。',ex_cta:'获取我的真实估算 →',ex_callbtn:'☎ 致电 (604) 907-3632',
      cx_eyb:'执业领域',cx_h2:'我们处理的伤害和 ICBC 案件',cx_sub:'从 ICBC 索赔到灾难性伤害，Sidhu Legal 代理卑诗省客户处理各类人身伤害和事故索赔。没看到您的情况？问我们，案件评估是免费的。',
      cx_1:'ICBC 索赔',cx_2:'车祸索赔',cx_3:'摩托车事故',cx_4:'行人事故',cx_5:'骑车人伤害',cx_6:'滑倒和跌倒',cx_7:'脑损伤',cx_8:'脊髓损伤',cx_9:'灾难性伤害',cx_10:'狗咬和动物攻击',cx_11:'意外死亡',cx_12:'长期残疾',cx_13:'工伤和责任索赔',cx_14:'产品责任',cx_15:'网约车（Uber 和 Lyft）事故',cx_16:'医疗事故',
      cx_notsure:'不确定您的案件属于哪类？<a href="#consult" style="color:#c9a040;font-weight:700;text-decoration:none;border-bottom:1px solid rgba(201,160,64,.4)">获取免费案件评估 →</a>',
      lx_label:'本地知识',lx_h2:'素里的伤害和 ICBC 索赔：您需要了解的',lx_intro:'素里是卑诗省最大、发展最快的城市之一，其高速公路和繁忙的主干道每年发生数千起碰撞。如果您在素里或周边受伤，以下是影响您索赔的本地背景。',
      lx_h3a:'素里事故多发地点',lx_pa:'1 号高速公路（横加公路）、King George 大道、Fraser 高速公路和 99 号高速公路承载着该市最繁忙的交通，而 152 街走廊以及 Pattullo 和 Port Mann 大桥的引道是常见的碰撞点。大雨和大雾是高速公路上的常见因素。',
      lx_h3b:'ICBC 与您的索赔',lx_pb:'卑诗省大多数汽车伤害都通过 ICBC 处理，其 Enhanced Care 系统无论过错与否都提供医疗和工资福利。我们确保 ICBC 支付您应得的全部福利，对拒赔和低额报价提出质疑，并追讨法律仍然允许的每一项额外索赔。根据卑诗省的《时效法》，您通常有 <strong>2 年</strong> 的时间采取行动。',
      lx_h3c:'接受治疗',lx_pc:'素里的严重伤害在素里纪念医院接受治疗，那是卑诗省最繁忙的创伤中心之一。保留每一份医疗记录和收据，它们对证明您的索赔至关重要。'
    },
    es: {
      ex_eyebrow:'Herramienta gratuita',ex_h2:'Estime el valor de su reclamo por lesiones',ex_sub:'Responda unas preguntas rápidas para una ilustración aproximada e instantánea de un posible rango de reclamo por lesiones. En BC, las lesiones automovilísticas se manejan a través del sistema Enhanced Care de ICBC, por lo que los montos reales varían según cada caso. Para una evaluación honesta, hable gratis con Shawn Sidhu.',
      ex_lbl_injury:'Tipo de lesión',ex_opt1:'Tejidos blandos / latigazo cervical',ex_opt2:'Huesos rotos / fracturas',ex_opt3:'Dolor crónico o daño nervioso',ex_opt4:'Lesiones graves o múltiples',ex_opt5:'Lesión cerebral o de la médula espinal',ex_opt6:'Catastrófica (parálisis, amputación, quemaduras)',ex_opt7:'Muerte por negligencia',ex_opt8:'Otro o no estoy seguro',
      ex_lbl_sev:'Gravedad',ex_minor:'Leve',ex_moderate:'Moderada',ex_severe:'Grave',ex_lbl_weeks:'Semanas sin poder trabajar',ex_lbl_wage:'Su ingreso semanal ($)',
      ex_rlabel1:'Rango potencial estimado',ex_rlabel2:'Toque un campo para actualizar',ex_uniq1:'Su caso es único',ex_uniq2:'Hablemos',ex_callmsg:'Un caso como el suyo merece una respuesta real, no una calculadora. Llámenos para una estimación gratuita y honesta de cuánto podría valer su reclamo.',
      ex_disc:'Esto es solo una ilustración aproximada y <b>no</b> es asesoramiento legal, una garantía ni una predicción de ningún beneficio o acuerdo de ICBC. La mejor manera de saber cuánto vale realmente su reclamo es una evaluación de caso gratuita y sin compromiso.',ex_cta:'Obtener mi estimación real →',ex_callbtn:'☎ Llamar (604) 907-3632',
      cx_eyb:'Áreas de práctica',cx_h2:'Casos de lesiones e ICBC que manejamos',cx_sub:'Desde reclamos de ICBC hasta lesiones catastróficas, Sidhu Legal representa a clientes de BC en toda la gama de reclamos por lesiones y accidentes. ¿No ve el suyo? Pregúntenos, la evaluación del caso es gratuita.',
      cx_1:'Reclamos de ICBC',cx_2:'Reclamos por accidentes de auto',cx_3:'Accidentes de motocicleta',cx_4:'Accidentes de peatones',cx_5:'Lesiones de ciclistas',cx_6:'Resbalones y caídas',cx_7:'Lesión cerebral',cx_8:'Lesión de la médula espinal',cx_9:'Lesión catastrófica',cx_10:'Mordeduras de perro y ataques de animales',cx_11:'Muerte por negligencia',cx_12:'Discapacidad a largo plazo',cx_13:'Reclamos laborales y de responsabilidad',cx_14:'Responsabilidad por productos',cx_15:'Accidentes de viajes compartidos (Uber y Lyft)',cx_16:'Negligencia médica',
      cx_notsure:'¿No está seguro de dónde encaja su caso? <a href="#consult" style="color:#c9a040;font-weight:700;text-decoration:none;border-bottom:1px solid rgba(201,160,64,.4)">Obtenga una evaluación gratuita →</a>',
      lx_label:'Conocimiento local',lx_h2:'Lesiones y reclamos de ICBC en Surrey: lo que debe saber',lx_intro:'Surrey es una de las ciudades más grandes y de más rápido crecimiento de BC, y sus autopistas y arterias concurridas ven miles de colisiones cada año. Si resultó herido en Surrey o sus alrededores, aquí está el contexto local que da forma a su reclamo.',
      lx_h3a:'Dónde ocurren los choques en Surrey',lx_pa:'La autopista 1 (la Trans-Canadá), King George Boulevard, Fraser Highway y la autopista 99 soportan el tráfico más pesado de la ciudad, mientras que el corredor de la calle 152 y los accesos a los puentes Pattullo y Port Mann son puntos de colisión frecuentes. La lluvia intensa y la niebla son factores comunes en las autopistas.',
      lx_h3b:'ICBC y su reclamo',lx_pb:'La mayoría de las lesiones automovilísticas en BC pasan por ICBC, cuyo sistema Enhanced Care brinda beneficios médicos y salariales sin importar la culpa. Nos aseguramos de que ICBC pague todos los beneficios que le corresponden, impugnamos las negativas y las ofertas bajas, y perseguimos cada reclamo adicional que la ley aún permite. Según la Limitation Act de BC, generalmente tiene <strong>2 años</strong> para actuar.',
      lx_h3c:'Recibir tratamiento',lx_pc:'Las lesiones graves en Surrey se tratan en el Surrey Memorial Hospital, uno de los centros de trauma más concurridos de BC. Conserve cada registro médico y recibo, son fundamentales para probar su reclamo.'
    }
  };
  function applyLX(lang){
    var t = (lang!=='en') ? window._LX[lang] : null;
    document.querySelectorAll('[data-lx]').forEach(function(el){
      var k = el.getAttribute('data-lx');
      if(el.dataset.lxorig===undefined) el.dataset.lxorig = el.innerHTML;
      if(lang==='en' || !t) el.innerHTML = el.dataset.lxorig;
      else if(t[k]!==undefined) el.innerHTML = t[k];
    });
    if(typeof window.vfRefresh==='function') window.vfRefresh();
  }
  var _prevSL = window.sidhuSetLang;
  window.sidhuSetLang = function(lang){
    if(typeof _prevSL==='function') _prevSL(lang);
    applyLX(lang);
  };
  applyLX(localStorage.getItem('sidhu_lang') || 'en');
})();
</script>
</body>

