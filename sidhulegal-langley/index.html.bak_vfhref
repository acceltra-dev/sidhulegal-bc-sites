  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #0d1b2a;
      --navy-2: #142233;
      --navy-3: #1a2d40;
      --gold: #c9a040;
      --gold-h: #d4ac4a;
      --text: #1a1a2e;
      --muted: #6b7280;
      --light: #f7f6f2;
      --white: #ffffff;
      --border: #e5e0d5;
      --radius: 10px;
    }

    html { scroll-behavior: smooth; overflow-x: hidden; width: 100%; }

    body {
      font-family: 'Inter', sans-serif;
      color: var(--text);
      background: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
      width: 100%;
      position: relative;
    }

    img { display: block; max-width: 100%; height: auto; }

    /* ===== NAV ===== */
    nav {
      position: fixed;
      top: 34px; left: 0; right: 0;
      z-index: 100;
      background: rgba(13,27,42,0.96);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(201,160,64,0.2);
      padding: 1rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: flex;
      flex-direction: column;
      text-decoration: none;
    }
    .nav-logo .firm { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; color: var(--gold); line-height: 1; }
    .nav-logo .tagline { font-size: 0.65rem; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.12em; margin-top: 3px; }
    .nav-links-small { display: flex; gap: 1.75rem; list-style: none; }
    .nav-links-small a { color: rgba(255,255,255,0.55); text-decoration: none; font-size: 0.82rem; font-weight: 500; transition: color 0.2s; }
    .nav-links-small a:hover { color: #fff; }

    /* ===== HERO ===== */
    #hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1611564494260-6f21b80af7ea?auto=format&fit=crop&w=1920&q=80');
      background-size: cover;
      background-position: center 30%;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        105deg,
        rgba(13,27,42,0.97) 0%,
        rgba(13,27,42,0.88) 50%,
        rgba(13,27,42,0.55) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 1180px;
      margin: 0 auto;
      padding: 10rem 2.5rem 5rem;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
      align-items: center;
      width: 100%;
    }

    .hero-left {}

    .hero-location {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--gold);
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      margin-bottom: 1.5rem;
    }
    .hero-location::before {
      content: '';
      display: block;
      width: 24px;
      height: 2px;
      background: var(--gold);
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      line-height: 1.1;
      color: #fff;
      margin-bottom: 1.25rem;
    }
    .hero-title span { color: var(--gold); }

    .hero-sub {
      color: rgba(255,255,255,0.65);
      font-size: 1rem;
      line-height: 1.8;
      margin-bottom: 2.25rem;
      max-width: 520px;
    }

    .hero-badges {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 2.25rem;
    }
    .badge {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(201,160,64,0.12);
      border: 1px solid rgba(201,160,64,0.25);
      color: var(--gold);
      padding: 0.35rem 0.85rem;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .badge::before {
      content: '';
      width: 5px; height: 5px;
      background: var(--gold);
      border-radius: 50%;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn-gold {
      background: var(--gold);
      color: var(--navy);
      border: none;
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.2s, transform 0.15s;
      font-family: 'Inter', sans-serif;
      letter-spacing: 0.01em;
    }
    .btn-gold:hover { background: var(--gold-h); transform: translateY(-2px); }

    .btn-ghost-white {
      background: transparent;
      color: #fff;
      border: 1px solid rgba(255,255,255,0.25);
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.2s, transform 0.15s;
      font-family: 'Inter', sans-serif;
    }
    .btn-ghost-white:hover { background: rgba(255,255,255,0.08); transform: translateY(-2px); }

    /* HERO FORM CARD */
    .hero-form-card {
      background: #fff;
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 24px 64px rgba(0,0,0,0.35);
    }
    .form-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.35rem;
      color: var(--navy);
      margin-bottom: 0.3rem;
    }
    .form-card-sub { font-size: 0.82rem; color: var(--muted); margin-bottom: 1.5rem; }

    .form-group { margin-bottom: 1rem; }
    .form-group label {
      display: block;
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.09em;
      margin-bottom: 0.4rem;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      background: var(--light);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.72rem 1rem;
      color: var(--text);
      font-size: 0.9rem;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border-color 0.2s;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: var(--gold); }
    .form-group textarea { resize: vertical; }

    .form-submit {
      width: 100%;
      background: var(--navy);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      padding: 0.95rem;
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      margin-top: 0.5rem;
      transition: background 0.2s, transform 0.15s;
      letter-spacing: 0.01em;
    }
    .form-submit:hover { background: var(--navy-3); transform: translateY(-1px); }

    .form-note { font-size: 0.72rem; color: var(--muted); text-align: center; margin-top: 0.75rem; }

    /* ===== TRUST BAR ===== */
    #trust {
      background: var(--navy);
      border-top: 1px solid rgba(201,160,64,0.2);
      border-bottom: 1px solid rgba(201,160,64,0.2);
      padding: 2rem 2.5rem;
    }
    .trust-grid {
      max-width: 1180px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }
    .trust-item { text-align: center; }
    .trust-num {
      font-family: 'Playfair Display', serif;
      font-size: 2.2rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .trust-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); margin-top: 0.35rem; text-transform: uppercase; letter-spacing: 0.08em; }

    /* ===== SECTIONS ===== */
    .section-wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: 5.5rem 2.5rem;
    }
    .section-label {
      display: inline-block;
      color: var(--gold);
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: var(--navy);
      margin-bottom: 1rem;
      line-height: 1.15;
    }
    .section-sub { color: var(--muted); font-size: 0.95rem; line-height: 1.8; max-width: 560px; }

    /* ===== PRACTICE AREAS ===== */
    #practice { background: var(--light); }

    .practice-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3rem;
    }

    .practice-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .practice-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(13,27,42,0.12);
      border-color: var(--gold);
    }

    .practice-card-img {
      width: 100%;
      height: 180px;
      object-fit: cover;
    }

    .practice-card-body { padding: 1.5rem; }
    .practice-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      color: var(--navy);
      margin-bottom: 0.5rem;
    }
    .practice-card-desc { font-size: 0.83rem; color: var(--muted); line-height: 1.7; margin-bottom: 1.1rem; }
    .practice-card-link {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--gold);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      transition: gap 0.2s;
    }
    .practice-card-link:hover { gap: 0.6rem; }

    /* ===== WHY US ===== */
    #why { background: #fff; }

    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .why-photo {
      border-radius: 16px;
      overflow: hidden;
      aspect-ratio: 4/5;
      position: relative;
    }
    .why-photo img { width: 100%; height: 100%; object-fit: cover; }
    .why-photo-badge {
      position: absolute;
      bottom: 1.5rem;
      left: 1.5rem;
      background: var(--gold);
      color: var(--navy);
      padding: 0.75rem 1.25rem;
      border-radius: 10px;
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1.4;
    }
    .why-photo-badge strong { display: block; font-size: 1.1rem; }

    .why-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-top: 2.5rem;
    }
    .why-item { display: flex; gap: 1.25rem; align-items: flex-start; }
    .why-num {
      width: 3px;
      border-radius: 2px;
      background: var(--gold);
      align-self: stretch;
      flex-shrink: 0;
    }
    .why-text h4 { font-size: 0.95rem; font-weight: 700; color: var(--navy); margin-bottom: 0.2rem; }
    .why-text p { font-size: 0.83rem; color: var(--muted); line-height: 1.65; }

    /* ===== LANGUAGES ===== */
    #languages { background: var(--navy); }

    .lang-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .lang-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem,3.5vw,2.4rem); color: #fff; margin: 0.75rem 0 1rem; }
    .lang-sub { color: rgba(255,255,255,0.55); font-size: 0.92rem; line-height: 1.8; }

    .lang-cards {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .lang-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(201,160,64,0.2);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    .lang-flag { font-size: 2rem; line-height: 1; }
    .lang-name { font-weight: 700; color: #fff; font-size: 1rem; }
    .lang-note { font-size: 0.78rem; color: rgba(255,255,255,0.45); margin-top: 0.15rem; }

    /* ===== TESTIMONIALS ===== */
    #testimonials { background: var(--light); }

    .testi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .testi-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.75rem;
    }
    .testi-stars { color: var(--gold); font-size: 0.9rem; letter-spacing: 0.1em; margin-bottom: 1rem; }
    .testi-text { font-size: 0.88rem; color: var(--muted); line-height: 1.75; margin-bottom: 1.25rem; font-style: italic; }
    .testi-author { font-size: 0.82rem; font-weight: 700; color: var(--navy); }
    .testi-detail { font-size: 0.76rem; color: var(--muted); margin-top: 0.15rem; }

    /* ===== FAQ ===== */
    #faq { background: #fff; }

    .faq-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 3rem;
    }
    .faq-item {
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }
    .faq-q {
      width: 100%;
      background: none;
      border: none;
      padding: 1.2rem 1.5rem;
      text-align: left;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--navy);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      font-family: 'Inter', sans-serif;
      transition: background 0.15s;
    }
    .faq-q:hover { background: var(--light); }
    .faq-q.open { background: var(--light); color: var(--gold); }
    .faq-arrow { font-size: 1.1rem; transition: transform 0.2s; flex-shrink: 0; }
    .faq-q.open .faq-arrow { transform: rotate(180deg); }
    .faq-a {
      padding: 0 1.5rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s;
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.75;
    }
    .faq-a.open { max-height: 300px; padding: 0 1.5rem 1.25rem; }

    /* ===== CTA SECTION ===== */
    #cta {
      background: var(--navy);
      position: relative;
      overflow: hidden;
    }
    #cta::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url('https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=1920&q=80') center/cover;
      opacity: 0.08;
    }
    .cta-inner {
      position: relative;
      z-index: 1;
      max-width: 1180px;
      margin: 0 auto;
      padding: 5.5rem 2.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .cta-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem,4vw,3rem); color: #fff; margin: 0.75rem 0 1rem; line-height: 1.1; }
    .cta-sub { color: rgba(255,255,255,0.55); font-size: 0.92rem; line-height: 1.8; margin-bottom: 2rem; }
    .cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

    .cta-info {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(201,160,64,0.2);
      border-radius: 16px;
      padding: 2rem;
    }
    .cta-info-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #fff; margin-bottom: 1.5rem; }
    .cta-info-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }
    .cta-info-item:last-child { margin-bottom: 0; }
    .cta-dot { width: 8px; height: 8px; background: var(--gold); border-radius: 50%; margin-top: 0.45rem; flex-shrink: 0; }
    .cta-info-text { font-size: 0.85rem; color: rgba(255,255,255,0.6); line-height: 1.6; }
    .cta-info-text strong { color: #fff; display: block; margin-bottom: 0.1rem; font-size: 0.9rem; }

    /* ===== FOOTER ===== */
    footer {
      background: #080f17;
      padding: 2rem 2.5rem;
      text-align: center;
      border-top: 1px solid rgba(201,160,64,0.15);
    }
    footer p { font-size: 0.8rem; color: rgba(255,255,255,0.3); }
    footer a { color: var(--gold); text-decoration: none; }

    /* ===== STICKY MOBILE CTA ===== */
    .sticky-cta {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 200;
      background: var(--navy);
      border-top: 1px solid rgba(201,160,64,0.25);
      padding: 0.85rem 1.5rem;
      gap: 0.75rem;
    }
    .sticky-cta a {
      flex: 1;
      text-align: center;
      padding: 0.75rem;
      border-radius: 8px;
      font-size: 0.88rem;
      font-weight: 700;
      text-decoration: none;
    }
    .sticky-call { background: var(--gold); color: var(--navy); }
    .sticky-consult { background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2); }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 900px) {
      .hero-content { grid-template-columns: 1fr; gap: 2.5rem; padding: 8rem 1.5rem 3rem; }
      .hero-title { font-size: 2.4rem; }
      .practice-grid, .testi-grid { grid-template-columns: 1fr; }
      .why-grid, .lang-inner, .cta-inner, .faq-grid { grid-template-columns: 1fr; gap: 2rem; }
      .why-photo { aspect-ratio: 16/9; }
      .trust-grid { grid-template-columns: repeat(2, 1fr); }
      nav { padding: 0.9rem 1.2rem; }
      .nav-links-small { display: none; }
      .section-wrap { padding: 4rem 1.5rem; }
      .sticky-cta { display: flex; }
      body { padding-bottom: 70px; }
    }

    /* AWARDS */
    #awards { background: #f9f8f6; padding: 3.5rem 2rem; border-top: 3px solid var(--gold); }
    .awards-inner { max-width: 1180px; margin: 0 auto; text-align: center; }
    .awards-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #999; margin-bottom: 0.4rem; display: block; }
    .awards-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--navy); margin-bottom: 2rem; }
    .awards-grid { display: flex; justify-content: center; align-items: center; gap: 3.5rem; flex-wrap: wrap; }
    .awards-grid img { height: 110px; width: auto; object-fit: contain; transition: transform 0.2s; }
    .awards-grid img:hover { transform: scale(1.05); }
    @media(max-width:600px) { .awards-grid { gap: 2rem; } .awards-grid img { height: 75px; } }
    /* PROVEN RESULTS */
    #proven-results { background: var(--navy); padding: 4rem 2rem; }
    .results-inner { max-width: 1180px; margin: 0 auto; text-align: center; }
    .results-inner .section-label { color: var(--gold); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; display: block; margin-bottom: 0.5rem; }
    .results-inner h2 { font-family: 'Playfair Display', serif; color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 2.5rem; }
    .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; margin-bottom: 2rem; }
    .result-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(201,160,64,0.2); border-radius: 12px; padding: 2rem 1.5rem; }
    .result-num { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 0.5rem; }
    .result-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; line-height: 1.4; }
    .results-footnote { font-size: 0.75rem; color: rgba(255,255,255,0.25); margin-top: 1.5rem; }
    @media(max-width:700px) { .results-grid { grid-template-columns: repeat(2,1fr); } }
    @media(max-width:420px) { .results-grid { grid-template-columns: 1fr; } }
  
    #map-section { padding: 0; line-height: 0; }
    #map-section iframe { width: 100%; height: 380px; border: 0; display: block; filter: grayscale(20%); }
  
/* ===== FLAT PRACTICE CARDS (Alberta style) ===== */
.flat-practice-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
.flat-practice-card{position:relative;background-size:cover;background-position:center;border-radius:12px;padding:2rem;border:1px solid #e8e4dc;transition:box-shadow 0.25s,transform 0.2s;overflow:hidden;cursor:default}
.flat-practice-card::before{content:'';position:absolute;inset:0;background:rgba(255,255,255,0.88);z-index:0;transition:background 0.25s}
.flat-practice-card:hover::before{background:rgba(255,255,255,0.80)}
.flat-practice-card:hover{box-shadow:0 8px 32px rgba(13,27,42,0.1);transform:translateY(-3px)}
.flat-practice-card>*{position:relative;z-index:1}
.flat-practice-card h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--navy,#0d1b2a);margin-bottom:0.6rem}
.flat-practice-card p{font-size:0.86rem;color:var(--muted,#6b7280);line-height:1.7}
.flat-practice-extra{display:none}
.flat-practice-extra.visible{display:block}
.flat-see-more{display:inline-flex;align-items:center;gap:0.5rem;margin-top:2rem;background:transparent;border:1px solid rgba(13,27,42,0.2);color:var(--navy,#0d1b2a);padding:0.7rem 1.5rem;border-radius:8px;font-size:0.88rem;font-weight:600;cursor:pointer;font-family:inherit;transition:border-color .2s,background .2s}
.flat-see-more:hover{background:rgba(13,27,42,0.05);border-color:var(--navy,#0d1b2a)}
@media(max-width:900px){.flat-practice-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.flat-practice-grid{grid-template-columns:1fr}}

  </style>

  <!-- FAQPage Schema -->
  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a personal injury lawyer cost in Langley?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sidhu Legal works on a contingency fee basis. You pay nothing upfront and we only get paid if we win your case. Your initial consultation is always completely free."
      }
    },
    {
      "@type": "Question",
      "name": "How long do I have to file a personal injury claim in BC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In British Columbia, the general limitation period is 2 years from the date of the incident. For ICBC claims, you must report within a shorter window. Contact us immediately to protect your rights."
      }
    },
    {
      "@type": "Question",
      "name": "What if ICBC already made me an offer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Do not accept any ICBC settlement without speaking to a lawyer first. Once you accept, you can't reopen your claim. ICBC's first offer is almost always far below what you're entitled to."
      }
    },
    {
      "@type": "Question",
      "name": "Can I still claim if the accident was partly my fault?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. BC follows a contributory negligence system. Even if you were partially at fault, you may still recover compensation proportional to the other party's fault. Call us to discuss your specific situation."
      }
    },
    {
      "@type": "Question",
      "name": "Do you serve clients outside of Langley?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We serve clients throughout the Fraser Valley and Lower Mainland including Surrey, Delta, Richmond, Abbotsford, Chilliwack, and beyond. Most meetings can be done by phone or video."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a personal injury case take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on the complexity of your case and the severity of your injuries. Simple cases can settle in a few months. Complex cases can take anywhere from 1 to 3 years. We give you a realistic timeline after reviewing your case."
      }
    }
  ]
}
  </script>

