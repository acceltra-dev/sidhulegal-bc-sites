if(_ST['hi'])_ST['hi']['see_less']='कम देखें';
if(_ST['hi'])_ST['hi']['faq_a_cost']='Sidhu Legal कंटिंजेंसी फीस आधार पर काम करता है। पहले कुछ नहीं देना होता और केवल तभी फीस लेते हैं जब मामला जीतते हैं। पहली परामर्श हमेशा पूरी तरह मुफ्त है।';
if(_ST['hi'])_ST['hi']['faq_a_bc_limit']='BC में आमतौर पर दुर्घटना की तारीख से 2 साल का समय है। कुछ ICBC रिपोर्टिंग समय-सीमाएं बहुत कम हैं। प्रतीक्षा न करें, आज ही संपर्क करें।';
if(_ST['hi'])_ST['hi']['faq_a_bc_offer']='बिना वकील से बात किए ICBC का कोई भी प्रस्ताव स्वीकार न करें। एक बार दस्तखत करने के बाद दावा हमेशा के लिए बंद हो जाता है। ICBC का पहला प्रस्ताव लगभग हमेशा आपके हक से बहुत कम होता है।';
if(_ST['hi'])_ST['hi']['faq_a_fault']='हाँ। भले ही आप आंशिक रूप से दोषी थे, आप फिर भी दूसरे पक्ष की जिम्मेदारी के अनुपात में मुआवजा प्राप्त कर सकते हैं। अपनी स्थिति की समीक्षा के लिए संपर्क करें।';
if(_ST['hi'])_ST['hi']['faq_a_time']='यह आपकी चोटों की गंभीरता और मामले की जटिलता पर निर्भर करता है। सरल मामले कुछ महीनों में सुलझ सकते हैं, गंभीर मामलों में 1 से 3 साल लग सकते हैं।';
if(_ST['hi'])_ST['hi']['faq_a_bc_serve']='हाँ। Sidhu Legal {city} और पूरे Lower Mainland में ग्राहकों की सेवा करता है। अधिकांश बैठकें फोन या वीडियो कॉल द्वारा की जा सकती हैं।';
if(_ST['hi'])_ST['hi']['faq_a_ab_limit']='अल्बर्टा में, घटना की तारीख से सामान्य सीमा अवधि 2 वर्ष है। कुछ दावों के लिए छोटी समय-सीमाएं लागू होती हैं। तुरंत संपर्क करें।';
if(_ST['hi'])_ST['hi']['faq_a_ab_offer']='बिना वकील से बात किए कोई भी समझौता स्वीकार न करें। बीमा कंपनियां कम से कम देने के लिए प्रशिक्षित हैं — हम सुनिश्चित करते हैं कि आपको वही मिले जिसके आप हकदार हैं।';
if(_ST['hi'])_ST['hi']['tactics_lbl']='जानें आपके खिलाफ क्या है';
if(_ST['hi'])_ST['hi']['tactics_h2']='बीमा कंपनी अभी क्या कर रही है';
if(_ST['hi'])_ST['hi']['tactics_sub']='जब से आपकी दुर्घटना दर्ज होती है, बीमाकर्ता की टीम काम पर लग जाती है। यहाँ बताया गया है कि वे क्या करते हैं और हम आपकी ओर से इसका जवाब कैसे देते हैं।';
if(_ST['hi'])_ST['hi']['tactic_word']='रणनीति';
if(_ST['hi'])_ST['hi']['tactic_t1']='वे तुरंत रिकॉर्ड किए गए बयान के लिए कॉल करते हैं';
if(_ST['hi'])_ST['hi']['tactic_t2']='चोटों की जानकारी से पहले ही जल्दी समझौते की पेशकश करते हैं';
if(_ST['hi'])_ST['hi']['tactic_t3']='वे अपना मेडिकल परीक्षक नियुक्त करते हैं';
if(_ST['hi'])_ST['hi']['tactic_t4']='वे आपके सोशल मीडिया की निगरानी करते हैं';
if(_ST['hi'])_ST['hi']['tactic_t5']='वे आपको देरी और थकान से कम राशि में समझौते पर मजबूर करते हैं';
if(_ST['hi'])_ST['hi']['tactic_d1']='एडजस्टर दुर्घटना के कुछ घंटों के भीतर संपर्क करते हैं, जब आप अभी भी सदमे में हो सकते हैं। आप जो भी कहते हैं वह आपके खिलाफ इस्तेमाल हो सकता है।';
if(_ST['hi'])_ST['hi']['tactic_d2']='सॉफ्ट टिशू की चोट और मानसिक प्रभाव हफ्तों या महीनों बाद उभर सकते हैं। जल्दी स्वीकार करने से दावा हमेशा के लिए बंद हो जाता है।';
if(_ST['hi'])_ST['hi']['tactic_d3']='बीमाकर्ता तथाकथित स्वतंत्र मेडिकल परीक्षकों का उपयोग करते हैं जो बीमाकर्ता द्वारा भुगतान किए जाते हैं। वे आपकी तरफ नहीं हैं।';
if(_ST['hi'])_ST['hi']['tactic_d4']='एक फोटो या पोस्ट को संदर्भ से बाहर निकालकर आपके खिलाफ इस्तेमाल किया जा सकता है। यह सामान्य अभ्यास है।';
if(_ST['hi'])_ST['hi']['tactic_d5']='बीमा कंपनियां जानती हैं कि वित्तीय दबाव लोगों को तोड़ देता है। महीनों की देरी के बाद कम राशि का प्रस्ताव आकर्षक लगता है।';
if(_ST['hi'])_ST['hi']['tactic_c1']='बीमा कंपनी से किसी से भी बात करने से पहले हम आपको बताते हैं कि क्या कहना है और क्या नहीं।';
if(_ST['hi'])_ST['hi']['tactic_c2']='हम कभी भी समझौते की अनुमति नहीं देते जब तक आपकी चोटों और नुकसानों की पूरी सीमा दस्तावेजीकृत न हो।';
if(_ST['hi'])_ST['hi']['tactic_c3']='हम स्वतंत्र विशेषज्ञों के साथ पक्षपाती मेडिकल रिपोर्टों को चुनौती देते हैं और आपकी वास्तविक स्थिति को दर्शाने वाला केस बनाते हैं।';
if(_ST['hi'])_ST['hi']['tactic_c4']='हम पहले दिन से डिजिटल गोपनीयता पर सलाह देते हैं ताकि कुछ भी आपके खिलाफ इस्तेमाल न हो सके।';
if(_ST['hi'])_ST['hi']['tactic_c5']='हम आक्रामक तरीके से काम करते हैं, मामला ट्रैक पर रखते हैं और पूरी कंटिंजेंसी पर काम करके वित्तीय दबाव दूर करते हैं।';
