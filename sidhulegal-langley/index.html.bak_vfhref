// Build reverse map: any translated string (lowercase) → key
var ALL_KEYS=['client_stories','the_process','common_q','our_office','get_in_touch','how_it_works','by_numbers',
  'pa_mv','pa_moto','pa_bike','pa_ped','pa_slip','pa_dog','pa_ltd','pa_ride','pa_truck','pa_burn','pa_family','pa_pi','pa_icbc',
  'opt_car','opt_slip','opt_ped','opt_moto','opt_other','opt_fam'];

function buildMap(keys){
  var m={};
  Object.keys(_ST).forEach(function(lang){
    keys.forEach(function(k){
      if(_ST[lang][k]) m[_ST[lang][k].toLowerCase()]=k;
    });
  });
  return m;
}

var LABEL_MAP, TITLE_MAP, PA_MAP, OPT_MAP;
function rebuildMaps(){
  LABEL_MAP=buildMap(['client_stories','the_process','common_q','our_office','get_in_touch','by_numbers']);
  TITLE_MAP=buildMap(['how_it_works']);
  PA_MAP=buildMap(['pa_mv','pa_moto','pa_bike','pa_ped','pa_slip','pa_dog','pa_ltd','pa_ride','pa_truck','pa_burn','pa_family','pa_pi','pa_icbc']);
  OPT_MAP=buildMap(['opt_car','opt_slip','opt_ped','opt_moto','opt_other','opt_fam']);
}
