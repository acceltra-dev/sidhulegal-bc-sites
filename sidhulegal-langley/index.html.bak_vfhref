if(_ST['en'])_ST['en']['consult_h2']='Get Your Free Case Review';
if(_ST['en'])_ST['en']['consult_sub']='Tell us what happened. We will assess your claim honestly and explain exactly what you are entitled to. No jargon, no pressure.';
