if(_ST['zh'])_ST['zh']['pd_car']='我们与保险公司抗争，确保您获得应有的全额赔偿，而非保险公司想要支付的金额。';
if(_ST['zh'])_ST['zh']['pd_brain']='严重伤害需要严肃认真的法律代理。我们为脑损伤、脊椎伤及其他灾难性伤害追求最大赔偿。';
if(_ST['zh'])_ST['zh']['pd_slip']='物业业主有法律责任保持场所安全。若因疏忽导致您跌倒，您可能有权获得重大赔偿。';
if(_ST['zh'])_ST['zh']['pd_moto']='摩托车骑手面临独特风险及保险公司偏见。我们为您争取每一分应得的赔偿。';
if(_ST['zh'])_ST['zh']['pd_death']='若您因他人疏忽失去亲人，我们代表您的家庭以同情与坚定追求全额赔偿。';
if(_ST['zh'])_ST['zh']['pd_ltd']='保险公司常常拒绝合法的长期伤残赔偿申请。我们对这些决定提出质疑，为您应得的福利而战。';
if(_ST['zh'])_ST['zh']['pd_ped']='被车辆撞伤的行人面临严重伤害。我们为医疗费、收入损失及长期护理费用争取全额赔偿。';
if(_ST['zh'])_ST['zh']['pd_bike']='骑行者是最脆弱的道路使用者之一。若您被车辆撞伤，您有权获得最大伤害赔偿。';
if(_ST['zh'])_ST['zh']['pd_dog']='宠物主人对其动物造成的伤害承担责任。烧伤受害者同样拥有强力的法律追索权。我们全力追讨身体伤害、疤痕及精神创伤的赔偿。';
if(_ST['zh'])_ST['zh']['pd_ride']='在Uber或Lyft中受伤？网约车案件的保险责任十分复杂。我们替您厘清，确保您获得应有赔偿。';
if(_ST['zh'])_ST['zh']['pd_product']='有缺陷的产品造成伤害，制造商须承担责任。我们追究伤害您的企业的法律责任。';
if(_ST['zh'])_ST['zh']['pd_med']='当医疗服务提供者未尽职责时，后果可能改变人的一生。我们为医疗过失受害者而战。';
