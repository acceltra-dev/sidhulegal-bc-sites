function _st(key) {
  var lang = window._sLang || 'en';
  var obj = _ST[lang] || _ST.en;
  return obj[key] || (_ST.en[key]) || key;
}

function sidhuSetLang(lang) {
  window._sLang = lang;
  var T = _ST[lang] || _ST.en;

  // Nav links by href
  document.querySelectorAll('.nav-links-small a, .nav-links a').forEach(function(a) {
    var h = a.getAttribute('href') || '';
    if (h === '#practice') a.textContent = T.nav_practice;
    else if (h === '#testimonials' || h === '#reviews') a.textContent = T.nav_reviews;
    else if (h === '#contact') a.textContent = T.nav_contact;
  });

  // Hero stat labels (ordered)
  var sl = document.querySelectorAll('.hero-stat-label');
  var slKeys = ['stat_recovered','stat_cases','stat_years'];
  sl.forEach(function(el, i){ if(slKeys[i]) el.textContent = T[slKeys[i]]; });

  // Results bar labels (ordered)
  var rl = document.querySelectorAll('.result-label');
  var rlKeys = ['bar_recovered','bar_cases','bar_years','bar_rating'];
  rl.forEach(function(el, i){ if(rlKeys[i]) el.textContent = T[rlKeys[i]]; });

  // Awards
  var al = document.querySelector('.awards-label');
  if (al) al.textContent = T.awards_label;
  var at = document.querySelector('.awards-title');
  if (at) at.textContent = T.awards_title;

  // Feature boxes (BC sites only — safe no-op on Alberta)
  var ft = document.querySelectorAll('.feature-title');
  var fd = document.querySelectorAll('.feature-desc');
  var ftKeys = ['f1_title','f2_title','f3_title'];
  var fdKeys = ['f1_desc','f2_desc','f3_desc'];
  ft.forEach(function(el, i){ if(ftKeys[i]) el.textContent = T[ftKeys[i]]; });
  fd.forEach(function(el, i){ if(fdKeys[i]) el.textContent = T[fdKeys[i]]; });

  // Section labels — match by current English OR translated content
  var engLabels = {
    'Why Clients Choose Us': 'why_label',
    'Why Sidhu Legal': 'why_sidhu_label',
    'What We Handle': 'practice_label',
    'Cases We Handle': 'practice_label',
    'Get Started Today': 'contact_label'
  };
  // Build reverse map from any previous translation
  Object.keys(_ST).forEach(function(l) {
    if (l === 'en') return;
    engLabels[_ST[l].why_label] = 'why_label';
    engLabels[_ST[l].practice_label] = 'practice_label';
    engLabels[_ST[l].contact_label] = 'contact_label';
    if(_ST[l].why_sidhu_label)engLabels[_ST[l].why_sidhu_label]='why_sidhu_label';
  });
  document.querySelectorAll('.section-label').forEach(function(el) {
    var txt = el.textContent.trim();
    if (engLabels[txt]) el.textContent = T[engLabels[txt]];
  });

  // CTA buttons
  document.querySelectorAll('.btn-ghost-white').forEach(function(b) {
    b.textContent = T.btn_case_review;
  });
  document.querySelectorAll('.at-form-submit').forEach(function(b) {
    b.textContent = T.btn_case_review;
  });
  document.querySelectorAll('.form-submit').forEach(function(b) {
    b.textContent = T.btn_main_submit;
  });

  // Form fields — placeholders
  document.querySelectorAll('input[name="name"]').forEach(function(i) {
    i.placeholder = i.classList.contains('at-') ? T.ph_at_name : T.ph_name;
  });
  // Distinguish at-card name inputs from main form
  document.querySelectorAll('.at-body input[name="name"]').forEach(function(i){ i.placeholder = T.ph_at_name; });
  document.querySelectorAll('.contact-form-card input[name="name"]').forEach(function(i){ i.placeholder = T.ph_name; });
  document.querySelectorAll('input[name="name"]').forEach(function(i){ i.placeholder = T.ph_name; });
  document.querySelectorAll('.at-body input[name="name"]').forEach(function(i){ i.placeholder = T.ph_at_name; });
  document.querySelectorAll('textarea[name="message"]').forEach(function(i){ i.placeholder = T.ph_message; });
  document.querySelectorAll('.at-body textarea[name="message"]').forEach(function(i){ i.placeholder = T.ph_at_msg; });

  // Contact form card
  var cft = document.querySelector('.contact-form-title');
  if (cft) cft.textContent = T.form_title;
  var cfs = document.querySelector('.contact-form-sub');
  if (cfs) cfs.textContent = T.form_sub;
  var fn = document.querySelector('.form-note');
  if (fn) fn.textContent = T.form_note;

  // Form labels (match by known English or previously translated)
  var labelMap = {};
  ['Full Name','label_name','Phone Number','label_phone','Type of Case','label_case','Brief Description (optional)','label_message'].forEach(function(v,i,a){ if(i%2===0) labelMap[v] = a[i+1]; });
  Object.keys(_ST).forEach(function(l){
    if(l==='en') return;
    ['label_name','label_phone','label_case','label_message'].forEach(function(k){
      if(_ST[l][k]) labelMap[_ST[l][k]] = k;
    });
  });
  document.querySelectorAll('.form-group label').forEach(function(el) {
    var txt = el.textContent.trim();
    if (labelMap[txt]) el.textContent = T[labelMap[txt]];
  });

  // Cookie banner
  var cb = document.querySelector('#cookie-banner p');
  if (cb) {
    cb.innerHTML = T.cookie_text + ' <a href="privacy-policy.html" style="color:#c9a040;text-decoration:underline">' + T.cookie_policy + '</a>';
  }
  var cbtn = document.querySelector('#cookie-banner button');
  if (cbtn) cbtn.textContent = T.cookie_accept;

  // Lang button label
  var lb = document.getElementById('sidhuLangBtn');
  if (lb) {
    var labels = {en:'EN',fr:'FR',pa:'ਪੰ',zh:'中',hi:'हि',es:'ES'};
    lb.innerHTML = (labels[lang]||lang.toUpperCase()) + ' &#9660;';
  }

  // Active state in menu
  document.querySelectorAll('#sidhuLangMenu li').forEach(function(li) {
    li.classList.toggle('slang-active', li.dataset.sl === lang);
  });

  localStorage.setItem('sidhu_lang', lang);
}

function sidhuToggleLang(e) {
  e.stopPropagation();
  var m = document.getElementById('sidhuLangMenu');
  if (m) m.classList.toggle('open');
}

document.addEventListener('click', function() {
  var m = document.getElementById('sidhuLangMenu');
  if (m) m.classList.remove('open');
});

// Patch form success/error messages to use translations
(function() {
  var origAt = window.atSubmit;
  if (typeof origAt === 'function') {
    window.atSubmit = function(e, form, accidentType, city) {
      return origAt.call(this, e, form, accidentType, city);
    };
  }
})();

// Restore saved language on load
(function() {
  var saved = localStorage.getItem('sidhu_lang');
  if (saved && saved !== 'en' && _ST[saved]) {
    sidhuSetLang(saved);
  }
})();
</script>
