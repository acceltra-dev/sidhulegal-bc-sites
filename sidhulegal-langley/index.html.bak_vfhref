<!-- HERO -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-left">
      <div class="hero-location">Personal Injury Lawyer in Langley, BC</div>
      <h1 class="hero-title">Injured in Langley?<br><span>We Fight For</span><br>What You Deserve.</h1>
      <p class="hero-sub">Sidhu Legal has helped hundreds of Langley residents recover <span style="color:var(--gold);font-weight:600">maximum compensation</span> after accidents, ICBC disputes, and personal injuries. No fees unless we win.</p>
      <div class="hero-cost-badge" style="display:inline-flex;align-items:center;gap:0.6rem;margin:0 0 1.6rem;padding:0.6rem 1rem;background:rgba(201,160,64,0.1);border:1px solid rgba(201,160,64,0.32);border-radius:8px;color:rgba(255,255,255,0.92);font-size:0.85rem;line-height:1.45;font-family:'Inter',sans-serif"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a040" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg><span><strong style="color:#c9a040;font-weight:700">$0 upfront cost.</strong> You pay nothing unless we win your case.</span></div>      <div class="hero-badges">
        <span class="badge" data-stc="trust_t1">No Fee Unless You Win</span>
        <span class="badge" data-stc="hero_free_consult">Free Consultation</span>
      </div>
      <div class="hero-cta">
        <a href="tel:+16049073632" class="btn-gold">Call (604) 907-3632</a>
        <a href="#consult" class="btn-ghost-white">Get Free Case Review</a>
      </div>
    </div>

    <div class="hero-form-card" id="consult">
      <div class="form-card-title">Free Case Evaluation</div>
      <p class="form-card-sub">Tell us what happened. We respond within 1 business day.</p>
      <form onsubmit="handleForm(event)" autocomplete="on">
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" placeholder="Your full name" required autocomplete="name">
        </div>
        <div class="form-group">
          <label>Phone Number</label>
          <input type="tel" name="phone" placeholder="(604) 555-0100" required autocomplete="tel">
        </div>
        <div class="form-group">
          <label>Type of Case</label>
          <select name="case_type" required>
            <option value="" data-stc="form_select_ph">Select...</option>
            <option data-stc="opt_car">Car Accident / ICBC Claim</option>
            <option data-stc="opt_slip">Slip and Fall</option>
            <option data-stc="opt_ped">Pedestrian Accident</option>
            <option data-stc="opt_moto">Motorcycle Accident</option>
            <option data-stc="opt_other">Other Personal Injury</option>
            <option data-stc="opt_fam">Family Law</option>
          </select>
        </div>
        <div class="form-group">
          <label>Brief Description (optional)</label>
          <textarea name="message" rows="2" placeholder="What happened? When did it occur?" autocomplete="on"></textarea>
        </div>
        <button type="submit" class="form-submit">Send My Free Case Review</button>
        <p class="form-note">100% confidential. No obligation. We respond same business day.</p>
      </form>
    </div>
  </div>
</section>

<!-- CASE VALUE CALCULATOR (BC) -->
<style>
.vf-est{background:#0d1b2a;color:#fff;padding:3.4rem 2.5rem}
.vf-wrap{max-width:1080px;margin:0 auto}
.vf-est .vf-eyebrow{color:#c9a040;font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.78rem}
.vf-est h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.9rem,4vw,2.8rem);margin:.4rem 0 .5rem;color:#fff}
.vf-est .vf-sub{color:#aab6c4;max-width:640px;margin-bottom:1.6rem}
.vf-est-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:2.5rem;align-items:start}
.vf-field{margin-bottom:1rem}
.vf-field label{display:block;font-size:.82rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#c9a040;margin-bottom:.5rem}
.vf-field select,.vf-field input{width:100%;padding:.85rem 1rem;border-radius:10px;border:1px solid rgba(201,160,64,.3);background:#16263a;color:#fff;font:inherit}
.vf-sev{display:flex;gap:.5rem;flex-wrap:wrap}
.vf-sev label{flex:1;min-width:90px;text-align:center;background:#16263a;border:1px solid rgba(201,160,64,.3);border-radius:10px;padding:.7rem;cursor:pointer;font-size:.9rem;color:#cfd6e0;font-weight:600;transition:.15s}
.vf-sev input{position:absolute;opacity:0}
.vf-sev label:has(input:checked){background:#c9a040;color:#0d1b2a;border-color:#c9a040}
.vf-est-result{background:linear-gradient(160deg,#16263a,#0d1b2a);border:1px solid rgba(201,160,64,.35);border-radius:16px;padding:2rem;text-align:center}
.vf-est-result .vf-rlabel{font-size:.8rem;text-transform:uppercase;letter-spacing:.08em;color:#aab6c4}
.vf-range{font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.8rem,4vw,2.6rem);color:#c9a040;margin:.5rem 0;font-weight:800}
.vf-est-result .vf-disc{font-size:.72rem;color:#8a98a8;line-height:1.6;margin-top:1rem}
.vf-est-result .vf-cta{display:inline-block;margin-top:1.2rem;background:#c9a040;color:#0d1b2a;padding:.85rem 1.6rem;border-radius:40px;font-weight:700;text-decoration:none}
.vf-est-result .vf-cta:hover{background:#d4ac4a}
@media(max-width:760px){.vf-est-grid{grid-template-columns:1fr}}
</style>
<section class="vf-est" id="estimate">
  <div class="vf-wrap">
    <span class="vf-eyebrow" data-lx="ex_eyebrow">Free Tool</span>
    <h2 data-lx="ex_h2">Estimate the Value of Your Injury Claim</h2>
    <p class="vf-sub">Answer a few quick questions for a rough, instant illustration of a potential injury claim range. In BC, auto injuries are handled through ICBC's Enhanced Care system, so real amounts vary case by case. For an honest assessment, talk to Shawn Sidhu for free.</p>
    <div class="vf-est-grid">
      <div>
        <div class="vf-field"><label data-lx="ex_lbl_injury">Type of injury</label>
          <select id="vf-injury">
            <option value="25000" data-lx="ex_opt1">Soft tissue / whiplash</option>
            <option value="55000" data-lx="ex_opt2">Broken bones / fractures</option>
            <option value="110000" data-lx="ex_opt3">Chronic pain or nerve damage</option>
            <option value="180000" data-lx="ex_opt4">Serious or multiple injuries</option>
            <option value="380000" data-lx="ex_opt5">Brain or spinal cord injury</option>
            <option value="600000" data-lx="ex_opt6">Catastrophic (paralysis, amputation, burns)</option>
            <option value="750000" data-lx="ex_opt7">Wrongful death</option>
            <option value="call" data-lx="ex_opt8">Other or not sure</option>
          </select></div>
        <div class="vf-field"><label data-lx="ex_lbl_sev">Severity</label>
          <div class="vf-sev">
            <label><input type="radio" name="vf-sev" value="0.6"><span data-lx="ex_minor">Minor</span></label>
            <label><input type="radio" name="vf-sev" value="1" checked><span data-lx="ex_moderate">Moderate</span></label>
            <label><input type="radio" name="vf-sev" value="1.8"><span data-lx="ex_severe">Severe</span></label>
          </div></div>
        <div class="vf-field"><label data-lx="ex_lbl_weeks">Weeks unable to work</label>
          <input type="number" id="vf-weeks" min="0" max="520" placeholder="e.g. 8" value="0"></div>
        <div class="vf-field"><label data-lx="ex_lbl_wage">Your weekly income ($)</label>
          <input type="number" id="vf-wage" min="0" placeholder="e.g. 1200" value="0"></div>
      </div>
      <div class="vf-est-result" id="vf-result">
        <div id="vf-numeric">
          <div class="vf-rlabel" data-lx="ex_rlabel1">Estimated potential range</div>
          <div class="vf-range" id="vf-range">$0</div>
          <div class="vf-rlabel" data-lx="ex_rlabel2">Tap a field to update</div>
        </div>
        <div id="vf-callmsg" style="display:none">
          <div class="vf-rlabel" data-lx="ex_uniq1">Your case is unique</div>
          <div class="vf-range" data-lx="ex_uniq2">Let&rsquo;s talk</div>
          <p style="color:#aab6c4;font-size:.92rem;line-height:1.6;margin:.5rem 0 0">A case like yours deserves a real answer, not a calculator. Call us for a free, honest estimate of what your claim could be worth.</p>
        </div>
        <p class="vf-disc">This is a rough illustration only and <b>not</b> legal advice, a guarantee, or a prediction of any ICBC benefit or settlement. The best way to find out what your claim is really worth is a free, no-obligation case review.</p>
        <a class="vf-cta" id="vf-cta" href="#consult" onclick="event.preventDefault();openEstimateModal();">Get My Real Estimate &rarr;</a>
      </div>
    </div>
  </div>
</section>
<!-- REAL ESTIMATE MODAL -->
<div id="est-modal" style="display:none;position:fixed;inset:0;z-index:10000;background:rgba(7,13,22,0.82);backdrop-filter:blur(3px);align-items:center;justify-content:center;padding:1.2rem" onclick="if(event.target===this)closeEstimateModal()">
  <div style="position:relative;max-width:460px;width:100%;background:linear-gradient(160deg,#16263a,#0d1b2a);border:1px solid rgba(201,160,64,0.4);border-radius:18px;padding:2.2rem 1.7rem 1.9rem;text-align:center;font-family:'Inter',sans-serif">
    <button onclick="closeEstimateModal()" aria-label="Close" style="position:absolute;top:0.9rem;right:1rem;background:none;border:none;color:#8a98a8;font-size:1.5rem;line-height:1;cursor:pointer">&times;</button>
    <div data-stc="em_eyebrow" style="color:#c9a040;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;font-size:0.76rem">Almost there</div>
    <h3 data-stc="em_title" style="font-family:'Playfair Display',serif;font-size:1.5rem;color:#fff;margin:0.4rem 0 0.7rem">Let&rsquo;s get your real estimate</h3>
    <p data-stc="em_body" style="color:#aab6c4;font-size:0.95rem;line-height:1.7;margin:0 0 1.4rem">The range above is a rough illustration. What your claim is actually worth depends on details only Shawn can assess, and the review is free. Here&rsquo;s the fastest way to get your real number.</p>
    <a href="tel:+16049073632" style="display:inline-flex;align-items:center;gap:0.6rem;background:#c9a040;color:#0d1b2a;font-size:1.25rem;font-weight:800;padding:0.85rem 1.8rem;border-radius:50px;text-decoration:none">&#9742; (604) 907-3632</a>
    <p data-stc="em_callsub" style="color:#8a98a8;font-size:0.82rem;margin:0.8rem 0 1.3rem">The fastest way to get answers. Free &amp; confidential.</p>
    <button data-stc="em_formbtn" onclick="closeEstimateModal();var c=document.getElementById('consult');if(c)c.scrollIntoView({behavior:'smooth',block:'start'});" style="width:100%;background:transparent;border:1px solid rgba(201,160,64,0.5);color:#fff;font-family:inherit;font-size:0.95rem;font-weight:600;padding:0.8rem;border-radius:10px;cursor:pointer">Prefer to type it out? Fill the quick form &rarr;</button>
    <div style="margin-top:1.5rem;text-align:left;background:#0d1b2a;border:1px solid rgba(201,160,64,0.18);border-radius:12px;padding:1rem 1.1rem">
      <div data-stc="em_handy" style="color:#c9a040;font-weight:700;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.55rem">Have these handy to speed it up</div>
