if(_ST['en'])_ST['en']['pc_product']='Product Liability';
if(_ST['en'])_ST['en']['pc_med']='Medical Malpractice';
if(_ST['en'])_ST['en']['pd_car']='We fight insurance companies so you receive the full settlement you deserve, not what they want to pay.';
if(_ST['en'])_ST['en']['pd_brain']='Serious injuries demand serious representation. We pursue maximum compensation for brain injuries, spinal injuries, and other catastrophic harm.';
if(_ST['en'])_ST['en']['pd_slip']='Property owners have a legal duty to keep premises safe. If negligence caused your fall, you may be entitled to significant compensation.';
if(_ST['en'])_ST['en']['pd_moto']='Riders face unique risks and insurer bias. We level the playing field and pursue every dollar of compensation available.';
if(_ST['en'])_ST['en']['pd_death']='If you\'ve lost a loved one due to someone else\'s negligence, we pursue full compensation on behalf of your family with compassion and determination.';
if(_ST['en'])_ST['en']['pd_ltd']='Insurance companies routinely deny legitimate long-term disability claims. We challenge those decisions and fight for the benefits you paid for.';
if(_ST['en'])_ST['en']['pd_ped']='Pedestrians struck by vehicles face serious injuries. We fight for full compensation including medical costs, lost income, and long-term care.';
if(_ST['en'])_ST['en']['pd_bike']='Cyclists are among the most vulnerable road users. If you were hit by a vehicle, you deserve maximum compensation for your injuries.';
if(_ST['en'])_ST['en']['pd_dog']='Animal owners are liable for injuries their pets cause. Burn victims also have strong legal claims. We pursue full compensation for physical injuries, scarring, and trauma.';
if(_ST['en'])_ST['en']['pd_ride']='Injured in an Uber or Lyft? Insurance coverage in rideshare cases is complex. We navigate it so you don\'t have to.';
if(_ST['en'])_ST['en']['pd_product']='Defective products that cause injury create manufacturer liability. We hold companies accountable when their products harm you.';
if(_ST['en'])_ST['en']['pd_med']='When healthcare providers fail in their duty of care, the consequences can be life-altering. We fight for victims of medical negligence.';
if(_ST['fr'])_ST['fr']['pc_car']='Accidents de voiture et de camion';
if(_ST['fr'])_ST['fr']['pc_brain']='Traumatismes crâniens et blessures catastrophiques';
if(_ST['fr'])_ST['fr']['pc_slip']='Glissade et chute';
if(_ST['fr'])_ST['fr']['pc_moto']='Accidents de moto';
if(_ST['fr'])_ST['fr']['pc_death']='Décès par négligence';
if(_ST['fr'])_ST['fr']['pc_ltd']='Refus de prestations d\'invalidité';
if(_ST['fr'])_ST['fr']['pc_ped']='Accidents de piétons';
if(_ST['fr'])_ST['fr']['pc_bike']='Accidents de vélo';
if(_ST['fr'])_ST['fr']['pc_dog']='Morsures, attaques et brûlures';
if(_ST['fr'])_ST['fr']['pc_ride']='Accidents de covoiturage';
if(_ST['fr'])_ST['fr']['pc_product']='Responsabilité du produit';
if(_ST['fr'])_ST['fr']['pc_med']='Faute médicale';
if(_ST['fr'])_ST['fr']['pd_car']='Nous combattons les compagnies d\'assurance pour que vous receviez la totalité du règlement que vous méritez, pas ce qu\'elles veulent bien payer.';
if(_ST['fr'])_ST['fr']['pd_brain']='Les blessures graves exigent une représentation sérieuse. Nous poursuivons une indemnisation maximale pour les traumatismes crâniens, les blessures à la colonne vertébrale et autres préjudices catastrophiques.';
if(_ST['fr'])_ST['fr']['pd_slip']='Les propriétaires ont l\'obligation légale de maintenir leurs locaux en sécurité. Si leur négligence a causé votre chute, vous pouvez avoir droit à une indemnisation importante.';
if(_ST['fr'])_ST['fr']['pd_moto']='Les motocyclistes font face à des risques uniques et à des préjugés des assureurs. Nous rééquilibrons le rapport de force et réclamons chaque dollar de compensation disponible.';
if(_ST['fr'])_ST['fr']['pd_death']='Si vous avez perdu un être cher à cause de la négligence d\'autrui, nous poursuivons une indemnisation complète au nom de votre famille avec compassion et détermination.';
if(_ST['fr'])_ST['fr']['pd_ltd']='Les compagnies d\'assurance refusent régulièrement des demandes d\'invalidité légitimes. Nous contestons ces décisions et nous battons pour les prestations auxquelles vous avez droit.';
if(_ST['fr'])_ST['fr']['pd_ped']='Les piétons heurtés par des véhicules subissent des blessures graves. Nous réclamons une indemnisation complète incluant les frais médicaux, la perte de revenus et les soins à long terme.';
if(_ST['fr'])_ST['fr']['pd_bike']='Les cyclistes sont parmi les usagers les plus vulnérables. Si vous avez été heurté par un véhicule, vous méritez une indemnisation maximale.';
if(_ST['fr'])_ST['fr']['pd_dog']='Les propriétaires d\'animaux sont responsables des blessures causées par leurs animaux. Les victimes de brûlures ont aussi de solides recours. Nous réclamons une indemnisation complète pour les préjudices physiques et le traumatisme.';
if(_ST['fr'])_ST['fr']['pd_ride']='Blessé dans un Uber ou Lyft ? La couverture d\'assurance est complexe dans ces cas. Nous la naviguons pour vous.';
if(_ST['fr'])_ST['fr']['pd_product']='Les produits défectueux causant des blessures engagent la responsabilité du fabricant. Nous tenons les entreprises responsables lorsque leurs produits vous font du mal.';
if(_ST['fr'])_ST['fr']['pd_med']='Lorsque les prestataires de soins manquent à leur devoir de diligence, les conséquences peuvent changer une vie. Nous défendons les victimes de négligence médicale.';
if(_ST['pa'])_ST['pa']['pc_car']='ਕਾਰ ਅਤੇ ਟਰੱਕ ਹਾਦਸੇ';
if(_ST['pa'])_ST['pa']['pc_brain']='ਦਿਮਾਗ਼ੀ ਅਤੇ ਗੰਭੀਰ ਸੱਟਾਂ';
if(_ST['pa'])_ST['pa']['pc_slip']='ਤਿਲਕਣ ਅਤੇ ਡਿੱਗਣਾ';
if(_ST['pa'])_ST['pa']['pc_moto']='ਮੋਟਰਸਾਈਕਲ ਹਾਦਸੇ';
if(_ST['pa'])_ST['pa']['pc_death']='ਲਾਪਰਵਾਹੀ ਕਾਰਨ ਮੌਤ';
if(_ST['pa'])_ST['pa']['pc_ltd']='LTD ਦਾਅਵਾ ਰੱਦ';
if(_ST['pa'])_ST['pa']['pc_ped']='ਪੈਦਲ ਯਾਤਰੀ ਹਾਦਸੇ';
if(_ST['pa'])_ST['pa']['pc_bike']='ਸਾਈਕਲ ਹਾਦਸੇ';
if(_ST['pa'])_ST['pa']['pc_dog']='ਕੁੱਤੇ ਦਾ ਕੱਟਣਾ, ਜਾਨਵਰਾਂ ਦੇ ਹਮਲੇ ਅਤੇ ਸੜਨ';
if(_ST['pa'])_ST['pa']['pc_ride']='ਰਾਈਡਸ਼ੇਅਰ ਹਾਦਸੇ';
if(_ST['pa'])_ST['pa']['pc_product']='ਉਤਪਾਦ ਦੇਣਦਾਰੀ';
if(_ST['pa'])_ST['pa']['pc_med']='ਮੈਡੀਕਲ ਲਾਪਰਵਾਹੀ';
if(_ST['pa'])_ST['pa']['pd_car']='ਅਸੀਂ ਬੀਮਾ ਕੰਪਨੀਆਂ ਨਾਲ ਲੜਦੇ ਹਾਂ ਤਾਂ ਜੋ ਤੁਹਾਨੂੰ ਪੂਰਾ ਮੁਆਵਜ਼ਾ ਮਿਲੇ ਜੋ ਤੁਸੀਂ ਅਸਲ ਵਿੱਚ ਹੱਕਦਾਰ ਹੋ।';
if(_ST['pa'])_ST['pa']['pd_brain']='ਗੰਭੀਰ ਸੱਟਾਂ ਲਈ ਗੰਭੀਰ ਨੁਮਾਇੰਦਗੀ ਦੀ ਲੋੜ ਹੈ। ਅਸੀਂ ਦਿਮਾਗ਼ੀ ਸੱਟਾਂ ਅਤੇ ਹੋਰ ਵਿਨਾਸ਼ਕਾਰੀ ਨੁਕਸਾਨ ਲਈ ਵੱਧ ਤੋਂ ਵੱਧ ਮੁਆਵਜ਼ਾ ਮੰਗਦੇ ਹਾਂ।';
if(_ST['pa'])_ST['pa']['pd_slip']='ਸੰਪਤੀ ਮਾਲਕਾਂ ਦੀ ਕਾਨੂੰਨੀ ਜ਼ਿੰਮੇਵਾਰੀ ਹੈ ਕਿ ਉਹ ਅਹਾਤੇ ਨੂੰ ਸੁਰੱਖਿਅਤ ਰੱਖਣ। ਜੇ ਲਾਪਰਵਾਹੀ ਕਾਰਨ ਤੁਸੀਂ ਡਿੱਗੇ ਤਾਂ ਤੁਸੀਂ ਮੁਆਵਜ਼ੇ ਦੇ ਹੱਕਦਾਰ ਹੋ ਸਕਦੇ ਹੋ।';
if(_ST['pa'])_ST['pa']['pd_moto']='ਮੋਟਰਸਾਈਕਲ ਸਵਾਰਾਂ ਨੂੰ ਵਿਲੱਖਣ ਖ਼ਤਰਿਆਂ ਅਤੇ ਬੀਮਾ ਪੱਖਪਾਤ ਦਾ ਸਾਹਮਣਾ ਕਰਨਾ ਪੈਂਦਾ ਹੈ। ਅਸੀਂ ਹਰ ਡਾਲਰ ਦਾ ਮੁਆਵਜ਼ਾ ਲੈਂਦੇ ਹਾਂ।';
if(_ST['pa'])_ST['pa']['pd_death']='ਜੇ ਕਿਸੇ ਦੀ ਲਾਪਰਵਾਹੀ ਕਾਰਨ ਤੁਸੀਂ ਪਿਆਰਾ ਗੁਆਇਆ ਹੈ, ਅਸੀਂ ਤੁਹਾਡੇ ਪਰਿਵਾਰ ਵੱਲੋਂ ਦਿਲੀ ਸੰਵੇਦਨਾ ਨਾਲ ਪੂਰਾ ਮੁਆਵਜ਼ਾ ਮੰਗਦੇ ਹਾਂ।';
if(_ST['pa'])_ST['pa']['pd_ltd']='ਬੀਮਾ ਕੰਪਨੀਆਂ ਅਕਸਰ ਜਾਇਜ਼ ਅਪੰਗਤਾ ਦਾਅਵੇ ਰੱਦ ਕਰਦੀਆਂ ਹਨ। ਅਸੀਂ ਉਨ੍ਹਾਂ ਫ਼ੈਸਲਿਆਂ ਨੂੰ ਚੁਣੌਤੀ ਦਿੰਦੇ ਹਾਂ ਅਤੇ ਤੁਹਾਡੇ ਹੱਕਾਂ ਲਈ ਲੜਦੇ ਹਾਂ।';
if(_ST['pa'])_ST['pa']['pd_ped']='ਵਾਹਨਾਂ ਵੱਲੋਂ ਟੱਕਰੇ ਪੈਦਲ ਯਾਤਰੀਆਂ ਨੂੰ ਗੰਭੀਰ ਸੱਟਾਂ ਲੱਗਦੀਆਂ ਹਨ। ਅਸੀਂ ਡਾਕਟਰੀ ਖਰਚੇ, ਆਮਦਨ ਦੀ ਘਾਟ ਅਤੇ ਦੀਰਘਕਾਲੀ ਦੇਖਭਾਲ ਲਈ ਪੂਰਾ ਮੁਆਵਜ਼ਾ ਮੰਗਦੇ ਹਾਂ।';
if(_ST['pa'])_ST['pa']['pd_bike']='ਸਾਈਕਲ ਸਵਾਰ ਸਭ ਤੋਂ ਕਮਜ਼ੋਰ ਸੜਕ ਉਪਭੋਗਤਾ ਹਨ। ਜੇ ਕਿਸੇ ਵਾਹਨ ਨੇ ਤੁਹਾਨੂੰ ਮਾਰਿਆ, ਤੁਸੀਂ ਪੂਰੇ ਮੁਆਵਜ਼ੇ ਦੇ ਹੱਕਦਾਰ ਹੋ।';
if(_ST['pa'])_ST['pa']['pd_dog']='ਜਾਨਵਰਾਂ ਦੇ ਮਾਲਕ ਆਪਣੇ ਪਾਲਤੂਆਂ ਵੱਲੋਂ ਸੱਟਾਂ ਲਈ ਜ਼ਿੰਮੇਵਾਰ ਹਨ। ਸੜਨ ਦੇ ਪੀੜਤਾਂ ਦੇ ਵੀ ਮਜ਼ਬੂਤ ਦਾਅਵੇ ਹਨ। ਅਸੀਂ ਸਰੀਰਕ ਸੱਟਾਂ ਅਤੇ ਦਾਗ਼ਾਂ ਦਾ ਪੂਰਾ ਮੁਆਵਜ਼ਾ ਮੰਗਦੇ ਹਾਂ।';
