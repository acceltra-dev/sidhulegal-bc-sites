if(_ST['fr'])_ST['fr']['strip_label']='Domaine de pratique';
if(_ST['fr'])_ST['fr']['strip_desc_pi']='Accidents de voiture, collisions piétonnes, chutes, et plus encore. Nous récupérons les frais médicaux, les salaires perdus et l\'indemnisation sur une base contingente.';
if(_ST['fr'])_ST['fr']['strip_desc_icbc']='Les ajusteurs ICBC sont formés pour minimiser votre règlement dès le premier jour. Nous connaissons chaque tactique qu\'ils utilisent et nous nous battons pour vous assurer le plein règlement.';
if(_ST['fr'])_ST['fr']['btn_call_review']='Appeler pour une évaluation gratuite';
