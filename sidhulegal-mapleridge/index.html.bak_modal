  <!-- FAQPage Schema -->
  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a personal injury lawyer cost in Maple Ridge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sidhu Legal works on a contingency fee basis. You pay nothing upfront and we only collect a fee if we win your case. Your initial consultation is always completely free."
      }
    },
    {
      "@type": "Question",
      "name": "How long do I have to file a claim after an injury in BC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In British Columbia, the general limitation period is 2 years from the date of injury. For ICBC claims, there are even shorter notice requirements. Contact us as soon as possible to protect your rights."
      }
    },
    {
      "@type": "Question",
      "name": "What if ICBC has already made me an offer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Do not accept any ICBC settlement without speaking to a lawyer first. Once you sign a release you cannot reopen your claim. ICBC's first offers are almost always far below what injured claimants are entitled to receive."
      }
    },
    {
      "@type": "Question",
      "name": "Can I claim if the accident was partly my fault?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. BC follows a contributory negligence framework. Even if you share some fault, you may still recover compensation proportional to the other party's share of responsibility. Call us to discuss your specific situation."
      }
    },
    {
      "@type": "Question",
      "name": "Do you serve clients outside of Maple Ridge?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We serve clients across the Lower Mainland and Fraser Valley including Pitt Meadows, Mission, Port Coquitlam, Surrey, Langley, and beyond. Most consultations and meetings can be done by phone or video call."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a personal injury case typically take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It varies based on the complexity of the case and the severity of your injuries. Straightforward cases can settle in a few months. Complex cases may take one to three years. After reviewing your situation, we will give you a realistic and honest timeline."
      }
    }
  ]
}
  </script>

