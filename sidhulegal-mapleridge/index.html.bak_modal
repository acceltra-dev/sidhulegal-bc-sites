if(_ST['en'])_ST['en']['icbc_they_1']='They Minimize Your Claim';
if(_ST['en'])_ST['en']['icbc_we_1']='We Maximize It.';
if(_ST['en'])_ST['en']['icbc_they_2']='They Delay Your Case';
if(_ST['en'])_ST['en']['icbc_we_2']='We Push It Forward.';
if(_ST['en'])_ST['en']['icbc_they_3']='They Hope You Give Up';
if(_ST['en'])_ST['en']['icbc_we_3']='We Never Do.';
if(_ST['en'])_ST['en']['rights_label']='Know Your Rights';
if(_ST['en'])_ST['en']['rights_h2']='You Have Rights.<br><span>We Make Sure ICBC Respects Them.</span>';
if(_ST['en'])_ST['en']['rights_r1']='<strong>Full coverage of medical costs</strong> including ongoing treatment, physiotherapy, and specialist care.';
if(_ST['en'])_ST['en']['rights_r2']='<strong>Lost wages and income replacement</strong> for every day you could not work due to your injuries.';
if(_ST['en'])_ST['en']['rights_r3']='<strong>Pain and suffering compensation</strong> for the physical and emotional toll the accident has taken on your life.';
if(_ST['en'])_ST['en']['rights_r4']='<strong>A full and fair ICBC settlement</strong> that reflects the true value of your claim, not their opening lowball offer.';
if(_ST['en'])_ST['en']['cta_lbl']='Ready to Get Started?';
if(_ST['en'])_ST['en']['cta_h2']='Get a Free Case Review Today';
if(_ST['en'])_ST['en']['cta_sub']='There are strict deadlines on ICBC and personal injury claims in BC. The sooner you call, the stronger your position.';
if(_ST['en'])_ST['en']['strip_label']='Practice Area';
if(_ST['en'])_ST['en']['strip_desc_pi']='Car accidents, pedestrian collisions, slip and falls, and more. We recover medical costs, lost wages, and pain and suffering compensation on a contingency basis. You pay nothing unless we win.';
if(_ST['en'])_ST['en']['strip_desc_icbc']='ICBC adjusters are trained to minimize your payout from day one. We know every tactic they use and fight back hard to ensure you receive the full settlement you are entitled to under BC law.';
if(_ST['en'])_ST['en']['btn_call_review']='Call for Free Review';
if(_ST['en'])_ST['en']['faq_bc_limit']='How long do I have to file my claim?';
if(_ST['en'])_ST['en']['faq_icbc_offer']='Should I accept the insurance settlement offer?';
if(_ST['en'])_ST['en']['faq_bc_serve']='Do you serve clients throughout the region?';
if(_ST['en'])_ST['en']['nav_tagline']='Personal Injury Lawyers';
if(_ST['en'])_ST['en']['nav_consult']='Free Review';
if(_ST['en'])_ST['en']['nav_faq']='FAQ';
if(_ST['en'])_ST['en']['see_more_areas']='See More Practice Areas';
if(_ST['en'])_ST['en']['see_less']='See Less';
if(_ST['en'])_ST['en']['faq_a_cost']='Sidhu Legal works on a contingency fee basis. You pay nothing upfront and we only get paid when we win your case. Your first consultation is always completely free.';
if(_ST['en'])_ST['en']['faq_a_bc_limit']='You generally have 2 years from the date of the accident to file a personal injury claim in BC. However, some ICBC reporting deadlines are much shorter. Do not wait. Call us today to protect your rights.';
if(_ST['en'])_ST['en']['faq_a_bc_offer']='Do not accept any ICBC offer without speaking to a lawyer first. Once you sign a release, your claim is closed permanently. ICBC\'s first offer is almost always significantly lower than what you are actually entitled to.';
if(_ST['en'])_ST['en']['faq_a_fault']='Yes. Even if you were partially at fault, you may still recover compensation proportional to the other party\'s share of fault. Call us to review your specific situation.';
if(_ST['en'])_ST['en']['faq_a_time']='It depends on the severity of your injuries and the complexity of the claim. Straightforward cases can settle in months. Serious or disputed cases can take 1 to 3 years. We give you a realistic timeline after reviewing your file.';
if(_ST['en'])_ST['en']['faq_a_bc_serve']='Yes. Sidhu Legal serves clients throughout {city} and the entire Lower Mainland. Most meetings can be conducted by phone or video call.';
if(_ST['en'])_ST['en']['faq_a_ab_limit']='In Alberta, the general limitation period is 2 years from the date of the incident. For some claims, shorter deadlines apply. Contact us immediately — delays can significantly weaken your case.';
if(_ST['en'])_ST['en']['faq_a_ab_offer']='Do not accept any settlement without speaking to a lawyer first. Once you sign, your claim is permanently closed. Insurance companies are trained to offer as little as possible — we make sure you get what you actually deserve.';
if(_ST['en'])_ST['en']['tactics_lbl']='Know What You Are Up Against';
if(_ST['en'])_ST['en']['tactics_h2']='What the Insurance Company Is Doing Right Now';
if(_ST['en'])_ST['en']['tactics_sub']='From the moment your accident is reported, the insurer\'s team goes to work. Here is exactly what they are doing, and how we counter it on your behalf.';
if(_ST['en'])_ST['en']['tactic_word']='Tactic';
if(_ST['en'])_ST['en']['tactic_t1']='They call you immediately for a recorded statement';
if(_ST['en'])_ST['en']['tactic_t2']='They make a quick settlement offer before you know your injuries';
if(_ST['en'])_ST['en']['tactic_t3']='They hire their own medical examiner';
if(_ST['en'])_ST['en']['tactic_t4']='They monitor your social media';
if(_ST['en'])_ST['en']['tactic_t5']='They delay and exhaust you into settling for less';
if(_ST['en'])_ST['en']['tactic_d1']='Adjusters reach out within hours of an accident, while you are still in shock or on pain medication. Anything you say can be used to minimize your claim.';
if(_ST['en'])_ST['en']['tactic_d2']='Soft tissue damage, chronic pain, and psychological impacts can take weeks or months to fully appear. Accepting early permanently closes your claim, even if your condition worsens.';
if(_ST['en'])_ST['en']['tactic_d3']='Insurers use so-called independent medical examiners who are paid by the insurer and routinely produce reports that downplay injuries. They are not on your side.';
if(_ST['en'])_ST['en']['tactic_d4']='A single photo, check-in, or post can be taken out of context and used to argue you are not as injured as you claim. This is standard practice.';
if(_ST['en'])_ST['en']['tactic_d5']='Insurance companies know that financial pressure and uncertainty wear people down. A lowball offer after months of delay looks more attractive when bills are piling up.';
if(_ST['en'])_ST['en']['tactic_c1']='We tell you exactly what to say and what not to say before you speak to anyone from the insurance company.';
if(_ST['en'])_ST['en']['tactic_c2']='We never let you settle until the full extent of your injuries and losses is documented and understood.';
if(_ST['en'])_ST['en']['tactic_c3']='We challenge biased medical reports with independent experts and build a medical case that reflects your real condition.';
if(_ST['en'])_ST['en']['tactic_c4']='We advise you on digital privacy from day one so nothing can be used against you.';
if(_ST['en'])_ST['en']['tactic_c5']='We move aggressively, keep your case on track, and take the financial pressure off by working on full contingency.';
if(_ST['en'])_ST['en']['hero_card_sub']='We respond the same business day.';
