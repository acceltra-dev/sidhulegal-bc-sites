<script>
// ── Phase-9c: why-section subtitle + why-box paragraph translation ─────────────
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;
var _o9c=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _o9c(lang);
