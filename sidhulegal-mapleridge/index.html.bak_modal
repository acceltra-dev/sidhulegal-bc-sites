if(_ST['hi'])_ST['hi']['pd_dog']='पशु मालिक अपने जानवरों द्वारा की गई चोटों के लिए जिम्मेदार हैं। जलने के पीड़ितों के भी मजबूत दावे हैं। हम शारीरिक चोट, निशान और आघात का पूरा मुआवजा दिलाते हैं।';
