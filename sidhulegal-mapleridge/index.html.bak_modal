if(_ST['hi'])_ST['hi']['why_p_local']='हम स्थानीय सड़कों, चौराहों और अदालतों को जानते हैं। आपके दावे में स्थानीय ज्ञान महत्वपूर्ण है।';
if(_ST['es'])_ST['es']['why_p_local']='Conocemos las carreteras, intersecciones y tribunales locales. El conocimiento local es importante para su reclamación.';
