<script id="hero-cost-i18n">
(function(){
  if(typeof window.sidhuSetLang!=='function')return;
  var TXT={
    en:['$0 upfront cost.','You pay nothing unless we win your case.'],
    fr:['0 $ de frais initiaux.','Vous ne payez rien sauf si nous gagnons votre dossier.'],
    pa:['$0 ਪੇਸ਼ਗੀ ਖਰਚਾ।','ਜਦੋਂ ਤੱਕ ਅਸੀਂ ਤੁਹਾਡਾ ਕੇਸ ਨਹੀਂ ਜਿੱਤਦੇ, ਤੁਸੀਂ ਕੁਝ ਨਹੀਂ ਦਿੰਦੇ।'],
    zh:['$0 预付费用。','除非我们赢得您的案件，否则您无需支付任何费用。'],
    hi:['$0 अग्रिम लागत।','जब तक हम आपका केस नहीं जीतते, तब तक आप कुछ नहीं देते।'],
    es:['$0 de costo inicial.','No paga nada a menos que ganemos su caso.']
  };
  function applyBadge(lang){
    var t=TXT[lang]||TXT.en;
    document.querySelectorAll('.hero-cost-badge, .hero-cost').forEach(function(b){
      var span=b.querySelector('span'); if(!span)return;
      var strong=span.querySelector('strong'); if(strong)strong.textContent=t[0];
      var node=strong?strong.nextSibling:span.firstChild;
      while(node&&node.nodeType!==3)node=node.nextSibling;
      if(node)node.nodeValue=' '+t[1]; else span.insertAdjacentText('beforeend',' '+t[1]);
    });
  }
  var _o=window.sidhuSetLang;
  window.sidhuSetLang=function(lang){ _o(lang); applyBadge(lang); };
  var sv=localStorage.getItem('sidhu_lang');
  if(sv&&_o&&TXT[sv])applyBadge(sv);
})();
</script></body>
<script>
// -- Phase-5 translation handler --
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;
function ac(s){return(s||'').replace(/{city}/g,window._sidhuCity);}
var _o5=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _o5(lang);
  var T=_ST[lang]||_ST.en;
  function tx(el,key){
    if(!el)return;
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(T[key])el.textContent=ac(T[key]);
  }
  document.querySelectorAll('[data-pc]').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    var v=T[el.dataset.pc];
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(v)el.textContent=v;
  });
  document.querySelectorAll('[data-pd]').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    var v=T[el.dataset.pd];
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(v)el.textContent=v;
  });
  tx(document.querySelector('.awards-title'),'awards_title_bc');
  tx(document.querySelector('#practice .section-sub'),'practice_intro_sub');
  tx(document.querySelector('#why .section-sub'),'why_section_intro');
  var wi=document.querySelectorAll('.why-text');
  if(wi[0]){tx(wi[0].querySelector('h4'),'why_t1_full');tx(wi[0].querySelector('p'),'why_d1_full');}
  if(wi[2]){tx(wi[2].querySelector('h4'),'why_direct_access');tx(wi[2].querySelector('p'),'why_direct_desc');}
  if(wi[3]){tx(wi[3].querySelector('h4'),'why_speak_lang');tx(wi[3].querySelector('p'),'why_speak_desc');}
  tx(document.querySelector('.lang-sub'),'lang_sub_para');
  document.querySelectorAll('.lang-note').forEach(function(el){tx(el,'lang_note_full');});
  var pc=document.querySelectorAll('#practice .practice-card');
  var ptk=['pc_practice_pi','pc_practice_icbc','pc_practice_family'];
  var pdk=['pd_practice_pi','pd_practice_icbc','pd_practice_family'];
  pc.forEach(function(card,i){
    tx(card.querySelector('.practice-card-title'),ptk[i]);
    tx(card.querySelector('.practice-card-desc'),pdk[i]);
    tx(card.querySelector('.practice-card-link'),'practice_card_cta');
  });
  var slMap={'what we handle':'what_we_handle_lbl','why sidhu legal':'why_sidhu_label','client stories':'client_stories_lbl','common questions':'common_q_lbl'};
  document.querySelectorAll('.section-label').forEach(function(el){
    var orig=(el.dataset.orig||el.textContent).trim().toLowerCase();
    if(!el.dataset.orig)el.dataset.orig=el.textContent.trim();
    if(lang==='en'){el.textContent=el.dataset.orig;return;}
    var k=slMap[orig];
    if(k&&T[k])el.textContent=T[k];
  });
};
var _sv5=localStorage.getItem('sidhu_lang');
if(_sv5&&_sv5!=='en'&&_ST[_sv5])window.sidhuSetLang(_sv5);
})();
</script>
