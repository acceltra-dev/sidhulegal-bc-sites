if(_ST['es'])_ST['es']['why_p_languages']='Asesoría legal en inglés, punjabi e hindi. Sin barrera idiomática entre usted y la justicia que merece.';
if(_ST['en'])_ST['en']['why_p_local']='We know the local roads, intersections, and courts. Local knowledge matters when building your injury claim.';
