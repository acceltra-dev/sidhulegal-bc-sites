  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #0d1b2a;
      --navy-2: #142233;
      --navy-3: #1a2d40;
      --gold: #c9a040;
      --gold-h: #d4ac4a;
      --text: #1a1a2e;
      --muted: #6b7280;
      --light: #f7f6f2;
      --cream: #faf8f4;
      --white: #ffffff;
      --border: #e5e0d5;
      --radius: 10px;
    }

    html { scroll-behavior: smooth; overflow-x: hidden; width: 100%; }

    body {
      font-family: 'Inter', sans-serif;
      color: var(--text);
      background: var(--white);
      line-height: 1.6;
      overflow-x: hidden;
      width: 100%;
      position: relative;
    }

    img { display: block; max-width: 100%; }

    /* ===== NAV ===== */
    nav {
      position: fixed;
      top: 34px; left: 0; right: 0;
      z-index: 100;
      background: rgba(13,27,42,0.95);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(201,160,64,0.18);
      padding: 1rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      display: flex;
      flex-direction: column;
      text-decoration: none;
    }
    .nav-logo .firm {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .nav-logo .tagline {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.4);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-top: 3px;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .nav-links {
      display: flex;
      gap: 1.75rem;
      list-style: none;
    }
    .nav-links a {
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      font-size: 0.82rem;
      font-weight: 500;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #fff; }

    /* ===== HERO ===== */
    #hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1541046469329-51deaf7358e8?auto=format&fit=crop&w=1920&q=80');
      background-size: cover;
      background-position: center 40%;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to right,
        rgba(13,27,42,0.95) 0%,
        rgba(13,27,42,0.82) 45%,
        rgba(13,27,42,0.60) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 1180px;
      margin: 0 auto;
      padding: 10rem 2.5rem 6rem;
      width: 100%;
    }

    .hero-left {
      max-width: 620px;
    }

    .hero-location-label {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      color: var(--gold);
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      margin-bottom: 1.75rem;
    }
    .hero-location-label::before {
      content: '';
      display: block;
      width: 28px;
      height: 2px;
      background: var(--gold);
      flex-shrink: 0;
    }

    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 5vw, 3.75rem);
      line-height: 1.1;
      color: #fff;
      margin-bottom: 1.5rem;
      font-weight: 700;
    }

    .hero-sub {
      color: rgba(255,255,255,0.68);
      font-size: 1.02rem;
      line-height: 1.85;
      margin-bottom: 2.5rem;
      max-width: 540px;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }

    .btn-gold {
      background: var(--gold);
      color: var(--navy);
      border: none;
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.2s, transform 0.15s;
      font-family: 'Inter', sans-serif;
      letter-spacing: 0.01em;
    }
    .btn-gold:hover { background: var(--gold-h); transform: translateY(-2px); }

    .btn-ghost-white {
      background: transparent;
      color: #fff;
      border: 1px solid rgba(255,255,255,0.28);
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.2s, transform 0.15s;
      font-family: 'Inter', sans-serif;
    }
    .btn-ghost-white:hover { background: rgba(255,255,255,0.08); transform: translateY(-2px); }

    .hero-trust-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: rgba(255,255,255,0.55);
      font-size: 0.82rem;
      font-weight: 500;
      flex-wrap: wrap;
    }
    .hero-trust-dot {
      color: var(--gold);
      font-size: 1.1rem;
      line-height: 1;
    }

    /* ===== FORM SECTION ===== */
    #form-section {
      background: var(--light);
      padding: 5rem 2.5rem;
    }

    .form-section-inner {
      max-width: 1180px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .form-left-heading {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: var(--navy);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }

    .form-left-sub {
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .form-trust-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-trust-item {
      display: flex;
      align-items: flex-start;
      gap: 0.85rem;
      font-size: 0.88rem;
      color: var(--text);
      line-height: 1.5;
    }

    .check-mark {
      color: var(--gold);
      font-size: 1rem;
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 0.05rem;
    }

    .form-card {
      background: var(--white);
      border-radius: 16px;
      padding: 2.25rem;
      box-shadow: 0 8px 40px rgba(13,27,42,0.09);
    }

    .form-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--navy);
      margin-bottom: 0.3rem;
    }
    .form-card-sub { font-size: 0.82rem; color: var(--muted); margin-bottom: 1.5rem; }

    .form-group { margin-bottom: 1rem; }
    .form-group label {
      display: block;
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.09em;
      margin-bottom: 0.4rem;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      background: var(--light);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.72rem 1rem;
      color: var(--text);
      font-size: 0.9rem;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border-color 0.2s;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: var(--gold); }
    .form-group textarea { resize: vertical; }

    .form-submit {
      width: 100%;
      background: var(--navy);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      padding: 0.95rem;
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      margin-top: 0.5rem;
      transition: background 0.2s, transform 0.15s;
      letter-spacing: 0.01em;
    }
    .form-submit:hover { background: var(--navy-3); transform: translateY(-1px); }

    .form-note { font-size: 0.72rem; color: var(--muted); text-align: center; margin-top: 0.75rem; }

    /* ===== SHARED SECTION WRAPPERS ===== */
    .section-wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: 5.5rem 2.5rem;
    }

    .section-label {
      display: inline-block;
      color: var(--gold);
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.5rem);
      color: var(--navy);
      margin-bottom: 1rem;
      line-height: 1.15;
    }

    .section-sub {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.8;
    }

    /* ===== AREAS WE SERVE ===== */
    #areas {
      background: var(--white);
    }

    .areas-heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.5rem);
      color: var(--navy);
      margin-bottom: 0.5rem;
      line-height: 1.15;
      text-align: center;
    }

    .areas-sub {
      color: var(--muted);
      font-size: 0.92rem;
      text-align: center;
      margin-bottom: 3rem;
    }

    .areas-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }

    .area-card {
      background: var(--light);
      border-top: 3px solid var(--gold);
      border-radius: 10px;
      padding: 1.5rem 1.25rem;
    }

    .area-card-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      color: var(--navy);
      margin-bottom: 0.6rem;
      font-weight: 700;
    }

    .area-card-desc {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.65;
    }

    /* ===== PRACTICE AREAS ===== */
    #practice {
      background: var(--light);
    }

    .practice-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3rem;
    }

    .practice-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .practice-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(13,27,42,0.1);
    }

    .practice-card-img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .practice-card-body { padding: 1.5rem; }

    .practice-card-title-wrap {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      margin-bottom: 0.6rem;
    }

    .practice-dot {
      width: 8px;
      height: 8px;
      background: var(--gold);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .practice-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      color: var(--navy);
      font-weight: 700;
    }

    .practice-card-desc {
      font-size: 0.83rem;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 1.1rem;
    }

    .practice-card-link {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--gold);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      transition: gap 0.2s;
    }
    .practice-card-link:hover { gap: 0.6rem; }

    /* ===== WHY US ===== */
    #why {
      background: var(--white);
    }

    .why-2x2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 3rem;
    }

    .why-box {
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 2rem;
    }

    .why-gold-bar {
      width: 30px;
      height: 3px;
      background: var(--gold);
      border-radius: 2px;
      margin-bottom: 1rem;
    }

    .why-box-heading {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--navy);
      font-family: 'Inter', sans-serif;
      margin-bottom: 0.65rem;
    }

    .why-box-desc {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.75;
    }

    /* ===== TESTIMONIALS ===== */
    #testimonials {
      background: var(--navy);
      padding: 5.5rem 2.5rem;
    }

    .testi-inner {
      max-width: 1180px;
      margin: 0 auto;
    }

    .testi-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .testi-header .section-label {
      color: rgba(201,160,64,0.75);
    }

    .testi-header .section-title {
      color: #fff;
    }

    .testi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .testi-card {
      background: var(--white);
      border-radius: 14px;
      padding: 2rem;
    }

    .testi-stars {
      color: var(--gold);
      font-size: 0.88rem;
      letter-spacing: 0.1em;
      margin-bottom: 1.1rem;
    }

    .testi-text {
      font-size: 0.87rem;
      color: var(--muted);
      line-height: 1.8;
      margin-bottom: 1.25rem;
      font-style: italic;
    }

    .testi-author {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--navy);
    }

    .testi-detail {
      font-size: 0.76rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    /* ===== FAQ ===== */
    #faq {
      background: var(--white);
    }

    .faq-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 3rem;
    }

    .faq-item {
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }

    .faq-q {
      width: 100%;
      background: none;
      border: none;
      padding: 1.2rem 1.5rem;
      text-align: left;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--navy);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      font-family: 'Inter', sans-serif;
      transition: background 0.15s;
    }
    .faq-q:hover { background: var(--light); }
    .faq-q.open { background: var(--light); color: var(--gold); }

    .faq-arrow {
      font-size: 1.1rem;
      transition: transform 0.22s;
      flex-shrink: 0;
    }
    .faq-q.open .faq-arrow { transform: rotate(180deg); }

    .faq-a {
      padding: 0 1.5rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s;
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.75;
    }
    .faq-a.open { max-height: 300px; padding: 0 1.5rem 1.25rem; }

    /* ===== CTA ===== */
    #cta {
      background: var(--cream);
      padding: 5.5rem 2.5rem;
      text-align: center;
    }

    .cta-inner {
      max-width: 680px;
      margin: 0 auto;
    }

    .cta-label {
      display: inline-block;
      color: var(--gold);
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      margin-bottom: 0.75rem;
    }

    .cta-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      color: var(--navy);
      margin-bottom: 1rem;
      line-height: 1.1;
    }

    .cta-sub {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.8;
      margin-bottom: 2.25rem;
    }

    .cta-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-navy-outline {
      background: transparent;
      color: var(--navy);
      border: 1.5px solid var(--navy);
      padding: 0.95rem 2rem;
      border-radius: var(--radius);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.2s, color 0.2s, transform 0.15s;
      font-family: 'Inter', sans-serif;
    }
    .btn-navy-outline:hover {
      background: var(--navy);
      color: #fff;
      transform: translateY(-2px);
    }

    /* ===== MAP ===== */
    #map {
      background: var(--navy);
      padding: 5rem 2.5rem;
    }

    .map-inner {
      max-width: 1180px;
      margin: 0 auto;
    }

    .map-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .map-header .section-label {
      color: rgba(201,160,64,0.7);
    }

    .map-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3vw, 2.3rem);
      color: #fff;
      margin-top: 0.5rem;
    }

    .map-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }

    .map-frame-wrap {
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid rgba(201,160,64,0.18);
      position: relative;
    }

    .map-click-overlay {
      position: absolute;
      inset: 0;
      z-index: 10;
      display: block;
    }

    .map-info {
      color: rgba(255,255,255,0.6);
      font-size: 0.9rem;
      line-height: 1.8;
      padding-top: 0.5rem;
    }

    .map-info-row {
      margin-bottom: 1.5rem;
    }

    .map-info-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gold);
      margin-bottom: 0.4rem;
    }

    .map-info-value {
      color: #fff;
      font-weight: 600;
    }

    .map-info-value a {
      color: #fff;
      text-decoration: none;
    }

    /* ===== FOOTER ===== */
    footer {
      background: #080f17;
      padding: 2rem 2.5rem;
      text-align: center;
      border-top: 1px solid rgba(201,160,64,0.12);
    }

    footer p { font-size: 0.8rem; color: rgba(255,255,255,0.3); }
    footer a { color: var(--gold); text-decoration: none; }
    footer p + p { margin-top: 0.4rem; }

    /* ===== STICKY MOBILE CTA ===== */
    .sticky-cta {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 200;
      background: var(--navy);
      border-top: 1px solid rgba(201,160,64,0.22);
      padding: 0.85rem 1.5rem;
      gap: 0.75rem;
    }

    .sticky-cta a {
      flex: 1;
      text-align: center;
      padding: 0.75rem;
      border-radius: 8px;
      font-size: 0.88rem;
      font-weight: 700;
      text-decoration: none;
    }

    .sticky-call { background: var(--gold); color: var(--navy); }
    .sticky-consult { background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.18); }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .areas-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 900px) {
      nav { padding: 0.9rem 1.2rem; }
      .nav-links { display: none; }

      .hero-content { padding: 8rem 1.5rem 4rem; }
      .hero-title { font-size: 2.3rem; }
      .hero-left { max-width: 100%; }

      #form-section { padding: 3.5rem 1.5rem; }
      .form-section-inner { grid-template-columns: 1fr; gap: 2.5rem; }

      .section-wrap { padding: 4rem 1.5rem; }

      .areas-grid { grid-template-columns: repeat(2, 1fr); }
      .practice-grid { grid-template-columns: 1fr; }
      .why-2x2 { grid-template-columns: 1fr; }
      .testi-grid { grid-template-columns: 1fr; }
      .faq-grid { grid-template-columns: 1fr; }
      .map-grid { grid-template-columns: 1fr; gap: 2rem; }

      #testimonials { padding: 4rem 1.5rem; }
      #cta { padding: 4rem 1.5rem; }
      #map { padding: 4rem 1.5rem; }

      .sticky-cta { display: flex; }
      body { padding-bottom: 72px; }
    }

    @media (max-width: 520px) {
      .areas-grid { grid-template-columns: 1fr; }
      .hero-title { font-size: 2rem; }
      .hero-trust-row { font-size: 0.78rem; }
    }

    /* AWARDS */
    #awards { background: #f9f8f6; padding: 3.5rem 2rem; border-top: 3px solid var(--gold); }
    .awards-inner { max-width: 1180px; margin: 0 auto; text-align: center; }
    .awards-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #999; margin-bottom: 0.4rem; display: block; }
    .awards-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--navy); margin-bottom: 2rem; }
    .awards-grid { display: flex; justify-content: center; align-items: center; gap: 3.5rem; flex-wrap: wrap; }
    .awards-grid img { height: 110px; width: auto; object-fit: contain; transition: transform 0.2s; }
    .awards-grid img:hover { transform: scale(1.05); }
    @media(max-width:600px) { .awards-grid { gap: 2rem; } .awards-grid img { height: 75px; } }
    /* PROVEN RESULTS */
    #proven-results { background: var(--navy); padding: 4rem 2rem; }
    .results-inner { max-width: 1180px; margin: 0 auto; text-align: center; }
    .results-inner .section-label { color: var(--gold); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; display: block; margin-bottom: 0.5rem; }
    .results-inner h2 { font-family: 'Playfair Display', serif; color: #fff; font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 2.5rem; }
    .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; margin-bottom: 2rem; }
    .result-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(201,160,64,0.2); border-radius: 12px; padding: 2rem 1.5rem; }
    #trust { background: var(--navy); padding: 1.5rem 2rem; border-bottom: 1px solid rgba(201,160,64,0.15); }
    .trust-grid { max-width: 1180px; margin: 0 auto; display: flex; justify-content: center; align-items: center; gap: 4rem; flex-wrap: wrap; text-align: center; }
    .trust-item {}
    .trust-num { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--gold); line-height: 1; }
    .trust-label { font-size: 0.76rem; color: rgba(255,255,255,0.5); margin-top: 0.3rem; text-transform: uppercase; letter-spacing: 0.08em; }
    @media(max-width:700px) { .trust-grid { gap: 2rem; } }
    .result-num { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 0.5rem; }
    .result-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; line-height: 1.4; }
    .results-footnote { font-size: 0.75rem; color: rgba(255,255,255,0.25); margin-top: 1.5rem; }
    @media(max-width:700px) { .results-grid { grid-template-columns: repeat(2,1fr); } }
    @media(max-width:420px) { .results-grid { grid-template-columns: 1fr; } }
  
    #map-section { padding: 0; line-height: 0; }
    #map-section iframe { width: 100%; height: 380px; border: 0; display: block; filter: grayscale(20%); }
  
/* ===== FLAT PRACTICE CARDS (Alberta style) ===== */
.flat-practice-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
.flat-practice-card{position:relative;background-size:cover;background-position:center;border-radius:12px;padding:2rem;border:1px solid #e8e4dc;transition:box-shadow 0.25s,transform 0.2s;overflow:hidden;cursor:default}
