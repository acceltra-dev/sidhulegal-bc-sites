<script>
// ── Full-site translation handler ─────────────────────────────────────────────
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;

function ac(s){return(s||'').replace(/\{city\}/g,window._sidhuCity);}

var _origFull=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _origFull(lang);
  var T=_ST[lang]||_ST.en;

  // Hero h1
  var h1=document.querySelector('.hero-title,.hero-h1');
  if(h1){if(!h1.dataset.orig)h1.dataset.orig=h1.innerHTML;
    if(lang==='en')h1.innerHTML=h1.dataset.orig;
    else if(T.hero_h1)h1.textContent=ac(T.hero_h1);}

  // Hero sub
  var hs=document.querySelector('.hero-sub');
  if(hs){if(!hs.dataset.orig)hs.dataset.orig=hs.innerHTML;
    if(lang==='en')hs.innerHTML=hs.dataset.orig;
    else if(T.hero_sub)hs.textContent=ac(T.hero_sub);}

  // Hero promises / bullets
  var ps=document.querySelectorAll('.hero-promise');
  var pk=['hero_p1','hero_p2','hero_p3','hero_p4'];
  ps.forEach(function(el,i){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(pk[i]&&T[pk[i]])el.textContent=T[pk[i]];
  });

  // Section titles with {city}
  var cityTitleKeys={
    'why_city_title':['why_city_title'],
    'practice_areas_city':['practice_areas_city'],
    'accidents_city':['accidents_city'],
    'faq_city':['faq_city'],
    'contact_heading_city':['contact_heading_city'],
    'map_heading':['map_heading'],
  };
  document.querySelectorAll('[data-stc]').forEach(function(el){
    var k=el.dataset.stc;
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(T[k])el.textContent=ac(T[k]);
  });

  // "What Our Clients Say" heading
  document.querySelectorAll('.section-title').forEach(function(el){
    var t=el.textContent.trim().toLowerCase();
    if(t==='what our clients say'||(el.dataset.orig&&el.dataset.orig.toLowerCase().indexOf('clients say')>-1)){
      if(!el.dataset.orig)el.dataset.orig=el.textContent;
      if(lang==='en')el.textContent=el.dataset.orig;
      else if(T.clients_say)el.textContent=T.clients_say;
    }
  });

  // Contact sub
  var cs=document.querySelector('.contact-sub');
  if(cs){if(!cs.dataset.orig)cs.dataset.orig=cs.textContent;
    if(lang==='en')cs.textContent=cs.dataset.orig;
    else if(T.contact_sub_city)cs.textContent=ac(T.contact_sub_city);}

  // Contact detail labels (Phone, Email, Office Address, Office Hours, Languages)
  var lblMap={'phone':T.contact_phone_lbl,'email':T.contact_email_lbl,
    'office address':T.contact_address_lbl,'office hours':T.contact_hours_lbl,
    'languages':T.contact_lang_lbl};
  document.querySelectorAll('.contact-detail-text strong').forEach(function(el){
    var k=el.textContent.trim().toLowerCase();
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en'){el.textContent=el.dataset.orig;}
    else if(lblMap[k])el.textContent=lblMap[k];
  });

  // Office Hours value
  var hv=document.querySelector('[data-contact-hours]');
  if(hv){if(!hv.dataset.orig)hv.dataset.orig=hv.textContent;
    if(lang==='en')hv.textContent=hv.dataset.orig;
    else if(T.contact_hours_val)hv.textContent=T.contact_hours_val;}

  // Areas We Serve
  var svl=document.querySelector('[data-serve-label]');
  if(svl){if(!svl.dataset.orig)svl.dataset.orig=svl.textContent;
    if(lang==='en')svl.textContent=svl.dataset.orig;
    else if(T.serve_label)svl.textContent=T.serve_label;}
  var svt=document.querySelector('[data-serve-title]');
  if(svt){if(!svt.dataset.orig)svt.dataset.orig=svt.textContent;
    if(lang==='en')svt.textContent=svt.dataset.orig;
    else if(T.serve_title)svt.textContent=T.serve_title;}

  // How It Works
  var hiwSub=document.querySelector('.hiw-header p,[data-hiw-sub]');
  if(hiwSub){if(!hiwSub.dataset.orig)hiwSub.dataset.orig=hiwSub.textContent;
    if(lang==='en')hiwSub.textContent=hiwSub.dataset.orig;
    else if(T.hiw_sub)hiwSub.textContent=T.hiw_sub;}
  var hiwTitles=document.querySelectorAll('.hiw-step-title');
  var hiwDescs=document.querySelectorAll('.hiw-step-desc');
  var htk=['hiw_s1_t','hiw_s2_t','hiw_s3_t'];
  var hdk=['hiw_s1_d','hiw_s2_d','hiw_s3_d'];
  hiwTitles.forEach(function(el,i){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(htk[i]&&T[htk[i]])el.textContent=T[htk[i]];
  });
  hiwDescs.forEach(function(el,i){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(hdk[i]&&T[hdk[i]])el.textContent=T[hdk[i]];
  });

  // FAQ questions (generic ones only, by data-faq attribute)
  document.querySelectorAll('[data-faq]').forEach(function(btn){
    var k=btn.dataset.faq;
    if(!btn.dataset.orig)btn.dataset.orig=btn.textContent.replace('▾','').replace('⌄','').trim();
    var arrow=btn.querySelector('.faq-arrow');
    var arrowHtml=arrow?arrow.outerHTML:'';
    if(lang==='en'){
      btn.textContent=btn.dataset.orig;
      if(arrowHtml)btn.innerHTML=btn.dataset.orig+'<span class="faq-arrow">&#8964;</span>';
    } else if(T[k]){
      btn.textContent=T[k];
      if(arrowHtml)btn.innerHTML=T[k]+'<span class="faq-arrow">&#8964;</span>';
    }
  });

  // Footer disclaimer
  document.querySelectorAll('[data-footer-disc]').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(T.footer_disclaimer)el.textContent=T.footer_disclaimer;
  });

  // Sticky CTA
  var sc=document.querySelector('.sticky-call');
  if(sc){if(!sc.dataset.orig)sc.dataset.orig=sc.textContent;
    if(lang==='en')sc.textContent=sc.dataset.orig;
    else if(T.sticky_call)sc.textContent=T.sticky_call;}
  var sr=document.querySelector('.sticky-form');
  if(sr){if(!sr.dataset.orig)sr.dataset.orig=sr.textContent;
    if(lang==='en')sr.textContent=sr.dataset.orig;
    else if(T.sticky_review)sr.textContent=T.sticky_review;}
};

// Re-apply saved language
var saved=localStorage.getItem('sidhu_lang');
if(saved&&saved!=='en'&&_ST[saved])window.sidhuSetLang(saved);
})();</script>
<script>
// ── Phase-3 translation handler ───────────────────────────────────────────────
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;
function ac(s){return(s||'').replace(/\{city\}/g,window._sidhuCity);}
var _o3=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _o3(lang);
  var T=_ST[lang]||_ST.en;
  function tx(el,key,html){
    if(!el)return;
    if(!el.dataset.orig)el.dataset.orig=html?el.innerHTML:el.textContent;
    if(lang==='en'){if(html)el.innerHTML=el.dataset.orig;else el.textContent=el.dataset.orig;}
    else if(T[key]){if(html)el.innerHTML=ac(T[key]);else el.textContent=ac(T[key]);}
  }
  // Hero pill
  tx(document.querySelector('.hero-pill'),'hero_pill',false);
  // Stats labels (BC hero-stats-card)
  var statMap={'recovered for clients':'stat_recovered','no upfront fees':'stat_fees','years serving clients':'stat_years','consultation':'stat_consult'};
  document.querySelectorAll('.hero-stats-card .stat-label').forEach(function(el){
    var k=statMap[(el.dataset.orig||el.textContent).trim().toLowerCase()];
    if(k)tx(el,k,false);
  });
  // ICBC fighter
  tx(document.querySelector('.icbc-heading'),'icbc_heading',false);
  tx(document.querySelector('.icbc-sub'),'icbc_sub',false);
  var tt=document.querySelectorAll('.icbc-they-text'),wt=document.querySelectorAll('.icbc-we-text');
  ['icbc_they_1','icbc_they_2','icbc_they_3'].forEach(function(k,i){if(tt[i])tx(tt[i],k,false);});
  ['icbc_we_1','icbc_we_2','icbc_we_3'].forEach(function(k,i){if(wt[i])tx(wt[i],k,false);});
  // Rights section
  tx(document.querySelector('#rights .section-label'),'rights_label',false);
  tx(document.querySelector('.rights-statement'),'rights_h2',true);
  var rli=document.querySelectorAll('.rights-list li');
  ['rights_r1','rights_r2','rights_r3','rights_r4'].forEach(function(k,i){if(rli[i])tx(rli[i],k,true);});
  // Consult
  tx(document.querySelector('#consult .section-label'),'consult_label',false);
  tx(document.querySelector('#consult h2'),'consult_h2',false);
  tx(document.querySelector('.consult-sub'),'consult_sub',false);
  var ts=document.querySelectorAll('.trust-bullet-text strong'),td=document.querySelectorAll('.trust-bullet-text span');
  ['trust_t1','trust_t2','trust_t3','trust_t4'].forEach(function(k,i){if(ts[i])tx(ts[i],k,false);});
  ['trust_d1','trust_d2','trust_d3','trust_d4'].forEach(function(k,i){if(td[i])tx(td[i],k,false);});
  // Form card
  tx(document.querySelector('.form-card-title'),'form_card_title',false);
  tx(document.querySelector('.form-card-sub'),'form_card_sub',false);
  // AT section
  tx(document.querySelector('.at-label,.at-section .section-label'),'cases_label',false);
  tx(document.querySelector('.at-section .at-header p, #accident-types .at-header p'),'at_intro',false);
  // CTA section
  tx(document.querySelector('.cta-label'),'cta_lbl',false);
  tx(document.querySelector('.cta-title'),'cta_h2',false);
  tx(document.querySelector('.cta-sub'),'cta_sub',false);
  // Map-CTA contact labels
  var ciMap={'address':T.contact_address_lbl,'phone':T.contact_phone_lbl,'email':T.contact_email_lbl,'hours':T.contact_hours_lbl};
  document.querySelectorAll('.ci-text strong').forEach(function(el){
    var k=(el.textContent||'').trim().toLowerCase();
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(ciMap[k])el.textContent=ciMap[k];
  });
  // ── Practice strips (Burnaby) ───────────────────────────────────────────────
  // Testimonials heading
  var tH2=document.querySelector('#testimonials .section-title');
  if(tH2){if(!tH2.dataset.orig)tH2.dataset.orig=tH2.textContent;
    if(lang==='en')tH2.textContent=tH2.dataset.orig;
    else if(T.clients_say)tH2.textContent=T.clients_say;}
  document.querySelectorAll('.strip-label').forEach(function(el){tx(el,'strip_label',false);});
  var sdescs=document.querySelectorAll('.strip-desc');
  if(sdescs[0])tx(sdescs[0],'strip_desc_pi',false);
  if(sdescs[1])tx(sdescs[1],'strip_desc_icbc',false);
  document.querySelectorAll('.btn-outline-navy').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent.replace(/→/g,'').replace(/&#8594;/g,'').trim();
    if(lang==='en')el.textContent=el.dataset.orig+' →';
    else if(T.btn_call_review)el.textContent=T.btn_call_review+' →';
  });
  // ── FAQ heading fallback (sites where data-stc was not added) ───────────────
  var faqH2=document.querySelector('#faq .section-title:not([data-stc])');
  if(faqH2){
    if(!faqH2.dataset.orig)faqH2.dataset.orig=faqH2.textContent;
    if(lang==='en')faqH2.textContent=faqH2.dataset.orig;
    else if(T.faq_city)faqH2.textContent=ac(T.faq_city);
  }
  // ── FAQ button pattern matching (for sites without data-faq) ────────────────
  var faqPat=[
    {r:/how much.*cost|what.*cost.*lawyer/i,           k:'faq_cost'},
    {r:/how long.*file|deadline|limitation period/i,   k:'faq_bc_limit'},
    {r:/already.*offer|should.*accept|accept.*offer|made.*offer/i, k:'faq_icbc_offer'},
    {r:/partly.*fault|partial.*fault/i,                k:'faq_fault'},
    {r:/how long.*case.*take|how long.*take|case.*take/i, k:'faq_time'},
    {r:/serve.*outside|outside.*area|other.*area|throughout|lower mainland|languages/i, k:'faq_bc_serve'},
  ];
  document.querySelectorAll('.faq-q:not([data-faq])').forEach(function(btn){
    var raw=btn.textContent.replace(/[⌄▾▼⌄]/g,'').trim();
    if(!raw)return;
    var arrow=btn.querySelector('.faq-arrow');
    var arrowHtml=arrow?arrow.outerHTML:'';
    for(var i=0;i<faqPat.length;i++){
      if(faqPat[i].r.test(raw)){
        var k=faqPat[i].k;
        if(!btn.dataset.orig)btn.dataset.orig=raw;
        if(lang==='en')btn.innerHTML=btn.dataset.orig+(arrowHtml||'');
        else if(T[k])btn.innerHTML=T[k]+(arrowHtml||'');
        break;
      }
    }
  });
};
var _sv=localStorage.getItem('sidhu_lang');
if(_sv&&_sv!=='en'&&_ST[_sv])window.sidhuSetLang(_sv);
})();
</script>
<script>
// ── Phase-4 translation handler ───────────────────────────────────────────────
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;
function ac(s){return(s||'').replace(/\{city\}/g,window._sidhuCity);}
var _o4=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _o4(lang);
  var T=_ST[lang]||_ST.en;
  // Nav tagline
  var tg=document.querySelector('.tagline');
  if(tg){if(!tg.dataset.orig)tg.dataset.orig=tg.textContent;
    if(lang==='en')tg.textContent=tg.dataset.orig;
    else if(T.nav_tagline)tg.textContent=T.nav_tagline;}
  // Nav links #consult and #faq
  document.querySelectorAll('.nav-links-small a,.nav-links a').forEach(function(a){
    var h=(a.getAttribute('href')||'').toLowerCase().trim();
    if(h!=='#consult'&&h!=='#faq')return;
    if(!a.dataset.orig)a.dataset.orig=a.textContent;
    if(lang==='en')a.textContent=a.dataset.orig;
    else if(h==='#consult'&&T.nav_consult)a.textContent=T.nav_consult;
    else if(h==='#faq'&&T.nav_faq)a.textContent=T.nav_faq;
    else if(h==='#why'&&T.nav_why)a.textContent=T.nav_why;
    else if(h==='#areas'&&T.nav_areas)a.textContent=T.nav_areas;
  });
  // Sticky consult button (Burnaby uses .sticky-consult)
  var stc=document.querySelector('.sticky-consult');
  if(stc){if(!stc.dataset.orig)stc.dataset.orig=stc.textContent;
    if(lang==='en')stc.textContent=stc.dataset.orig;
    else if(T.sticky_review)stc.textContent=T.sticky_review;}
  // flat-see-more toggle (BC)
  var sm=document.querySelector('.flat-see-more');
  if(sm){
    var isOpen=sm.classList.contains('open');
    if(lang==='en')sm.innerHTML=isOpen?'See Less &#8963;':'See More Practice Areas &#8964;';
    else{
      var mt=T.see_more_areas||'See More Practice Areas';
      var lt=T.see_less||'See Less';
      sm.innerHTML=isOpen?(lt+' &#8963;'):(mt+' &#8964;');
    }
  }
  // FAQ answers — match answer to question via .faq-item wrapper
  var faqAMap={
    'faq_cost':'faq_a_cost',
    'faq_bc_limit':'faq_a_bc_limit',
    'faq_icbc_offer':'faq_a_bc_offer',
    'faq_fault':'faq_a_fault',
    'faq_time':'faq_a_time',
    'faq_bc_serve':'faq_a_bc_serve',
    'faq_ab_limit':'faq_a_ab_limit',
    'faq_ab_offer':'faq_a_ab_offer',
  };
  var faqPatA=[
    {r:/file.*alberta|alberta.*limitation|claim.*alberta|alberta.*claim/i,k:'faq_ab_limit'},
    {r:/insurance company.*offer|company.*already.*offer/i,k:'faq_ab_offer'},
    {r:/how long.*file|icbc.*claim|bc.*limitation|british columbia/i,k:'faq_bc_limit'},
    {r:/icbc.*offer|icbc.*already|already.*icbc/i,k:'faq_icbc_offer'},
    {r:/should.*accept.*offer|already.*made.*offer|offer.*should.*accept/i,k:'faq_icbc_offer'},
    {r:/partly.*fault|partial.*fault/i,k:'faq_fault'},
    {r:/how long.*case|case.*take/i,k:'faq_time'},
    {r:/serve.*throughout|serve.*outside|lower mainland|outside.*area|throughout.*region/i,k:'faq_bc_serve'},
    {r:/how much.*cost|cost.*lawyer/i,k:'faq_cost'},
  ];
  document.querySelectorAll('.faq-item').forEach(function(item){
    var btn=item.querySelector('.faq-q');
    var ans=item.querySelector('.faq-a');
    if(!btn||!ans)return;
    var qKey=btn.dataset.faq||null;
    if(!qKey){
      var raw=(btn.dataset.orig||btn.textContent).replace(/[\u22c4\u25be\u25bc\u2304]/g,'').replace(/\s+/g,' ').trim();
      for(var i=0;i<faqPatA.length;i++){if(faqPatA[i].r.test(raw)){qKey=faqPatA[i].k;break;}}
    }
    if(!qKey)return;
    var aKey=faqAMap[qKey];
    if(!aKey)return;
    if(!ans.dataset.orig)ans.dataset.orig=ans.textContent;
    if(lang==='en')ans.textContent=ans.dataset.orig;
    else if(T[aKey])ans.textContent=ac(T[aKey]);
  });
  // Tactics section (Alberta only)
  var tacSec=document.querySelector('#tactics');
  if(tacSec){
    var tacLbl=tacSec.querySelector('.section-label');
    if(tacLbl){if(!tacLbl.dataset.orig)tacLbl.dataset.orig=tacLbl.textContent;
      if(lang==='en')tacLbl.textContent=tacLbl.dataset.orig;
      else if(T.tactics_lbl)tacLbl.textContent=T.tactics_lbl;}
    var tacH2=tacSec.querySelector('.section-title');
    if(tacH2){if(!tacH2.dataset.orig)tacH2.dataset.orig=tacH2.textContent;
      if(lang==='en')tacH2.textContent=tacH2.dataset.orig;
      else if(T.tactics_h2)tacH2.textContent=T.tactics_h2;}
    var tacSub=tacSec.querySelector('.tactics-intro');
    if(tacSub){if(!tacSub.dataset.orig)tacSub.dataset.orig=tacSub.textContent;
      if(lang==='en')tacSub.textContent=tacSub.dataset.orig;
      else if(T.tactics_sub)tacSub.textContent=T.tactics_sub;}
    tacSec.querySelectorAll('.tactic-card').forEach(function(card,i){
      var n=i+1;
      var lbl=card.querySelector('.tactic-label');
      if(lbl){if(!lbl.dataset.orig)lbl.dataset.orig=lbl.textContent;
        if(lang==='en')lbl.textContent=lbl.dataset.orig;
        else if(T.tactic_word){var num=lbl.dataset.orig.replace(/[^0-9]/g,'');lbl.textContent=T.tactic_word+(num?' '+num:'');}}
      var tt=card.querySelector('.tactic-title');
      if(tt){if(!tt.dataset.orig)tt.dataset.orig=tt.textContent;
        if(lang==='en')tt.textContent=tt.dataset.orig;
        else if(T['tactic_t'+n])tt.textContent=T['tactic_t'+n];}
      var td=card.querySelector('.tactic-desc');
      if(td){if(!td.dataset.orig)td.dataset.orig=td.textContent;
        if(lang==='en')td.textContent=td.dataset.orig;
        else if(T['tactic_d'+n])td.textContent=T['tactic_d'+n];}
      var tc=card.querySelector('.tactic-counter');
      if(tc){if(!tc.dataset.orig)tc.dataset.orig=tc.textContent;
        if(lang==='en')tc.textContent=tc.dataset.orig;
        else if(T['tactic_c'+n])tc.textContent=T['tactic_c'+n];}
    });
  }
};
// Override flatToggle to stay translated after toggle
if(typeof flatToggle!=='undefined'){
  var _origFT=flatToggle;
  window.flatToggle=function(btn){
    _origFT(btn);
    var l2=localStorage.getItem('sidhu_lang')||'en';
    if(l2!=='en'&&_ST[l2]){
      var T2=_ST[l2];
      var open=btn.classList.contains('open');
      btn.innerHTML=open?((T2.see_less||'See Less')+' &#8963;'):((T2.see_more_areas||'See More Practice Areas')+' &#8964;');
    }
  };
}
var _sv=localStorage.getItem('sidhu_lang');
if(_sv&&_sv!=='en'&&_ST[_sv])window.sidhuSetLang(_sv);
})();
</script>
<script>
// ── Phase-5 translation handler ───────────────────────────────────────────────
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;
function ac(s){return(s||'').replace(/\{city\}/g,window._sidhuCity);}
var _o5=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _o5(lang);
  var T=_ST[lang]||_ST.en;
  function tx(el,key,useHtml){
    if(!el)return;
    if(!el.dataset.orig)el.dataset.orig=useHtml?el.innerHTML:el.textContent;
    if(lang==='en'){if(useHtml)el.innerHTML=el.dataset.orig;else el.textContent=el.dataset.orig;}
    else if(T[key]){if(useHtml)el.innerHTML=ac(T[key]);else el.textContent=ac(T[key]);}
  }
  // Hero card title/sub (Alberta)
  tx(document.querySelector('.hero-card-title'),'sticky_review',false);
  tx(document.querySelector('.hero-card-sub'),'hero_card_sub',false);
  // Hero promise bullets (pattern match)
  var promPat=[
    {r:/maximum compensation/i,k:'promise_max_comp'},
    {r:/no fee unless|don.t pay unless|you don.t pay/i,k:'promise_no_fee'},
    {r:/shawn personally/i,k:'promise_shawn'},
    {r:/free case review.*no obligation|case review.*obligation/i,k:'promise_free_obl'},
    {r:/speak directly.*lawyer|call now.*directly/i,k:'promise_call_direct'},
  ];
  document.querySelectorAll('.hero-promise').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en'){el.textContent=el.dataset.orig;return;}
    var raw=el.dataset.orig;
    for(var i=0;i<promPat.length;i++){
      if(promPat[i].r.test(raw)&&T[promPat[i].k]){el.textContent=T[promPat[i].k];return;}
    }
  });
  // Trust strip items (pattern match)
  var trustPat=[
    {r:/no fee unless/i,k:'trust_no_fee'},
    {r:/speak directly/i,k:'trust_speak_direct'},
    {r:/free case review/i,k:'sticky_review'},
  ];
  document.querySelectorAll('.trust-item').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en'){el.textContent=el.dataset.orig;return;}
    var raw=el.dataset.orig;
    for(var i=0;i<trustPat.length;i++){
      if(trustPat[i].r.test(raw)&&T[trustPat[i].k]){el.textContent=T[trustPat[i].k];return;}
    }
  });
  // Quote text (use generic translation; data-orig restores site-specific English)
  var qt=document.querySelector('.quote-text');
  if(qt){
    if(!qt.dataset.orig)qt.dataset.orig=qt.innerHTML;
    if(lang==='en')qt.innerHTML=qt.dataset.orig;
    else if(T.quote_text)qt.textContent=T.quote_text;
  }
  // Practice section sub (first one in #practice — Alberta city-specific roads text)
  var psub=document.querySelector('#practice .section-sub');
  if(psub){
    if(!psub.dataset.orig)psub.dataset.orig=psub.textContent;
    if(lang==='en')psub.textContent=psub.dataset.orig;
    else if(T.practice_sub_ab)psub.textContent=ac(T.practice_sub_ab);
  }
  // Contact section title + sub (Alberta #contact)
  var ctitle=document.querySelector('#contact .section-title');
  if(ctitle){
    if(!ctitle.dataset.orig)ctitle.dataset.orig=ctitle.textContent;
    if(lang==='en')ctitle.textContent=ctitle.dataset.orig;
    else if(T.contact_heading_city)ctitle.textContent=ac(T.contact_heading_city);
  }
  var csub=document.querySelector('#contact .section-sub');
  if(csub){
    if(!csub.dataset.orig)csub.dataset.orig=csub.textContent;
    if(lang==='en')csub.textContent=csub.dataset.orig;
    else if(T.contact_sub_city)csub.textContent=ac(T.contact_sub_city);
  }
  // Contact form submit button (Alberta contact section, inline-styled)
  var cSubmit=document.querySelector('#contact button[type="submit"]');
  if(cSubmit){
    if(!cSubmit.dataset.orig)cSubmit.dataset.orig=cSubmit.textContent;
    if(lang==='en')cSubmit.textContent=cSubmit.dataset.orig;
    else if(T.btn_main_submit)cSubmit.textContent=T.btn_main_submit+' →';
  }
  // Serve section heading (Alberta)
  tx(document.querySelector('.serve-h2'),'serve_h2_ab',false);
  // Case type pills (.pill and .pill-lt)
  var pillPat=[
    {r:/car accident/i,k:'pill_car'},
    {r:/slip/i,k:'pill_slip'},
    {r:/brain|catastrophic/i,k:'pill_brain'},
    {r:/motorcycle/i,k:'pill_moto'},
    {r:/truck/i,k:'pill_truck'},
    {r:/wrongful death/i,k:'pill_death'},
    {r:/^other/i,k:'pill_other'},
  ];
  document.querySelectorAll('.pill,.pill-lt').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en'){el.textContent=el.dataset.orig;return;}
    var raw=el.dataset.orig.trim();
    for(var i=0;i<pillPat.length;i++){
      if(pillPat[i].r.test(raw)&&T[pillPat[i].k]){el.textContent=T[pillPat[i].k];return;}
    }
  });
  // Footer law society line (BC and Alberta)
  document.querySelectorAll('footer p').forEach(function(el){
    if(!el.dataset.lawType){
      var t=el.textContent.trim();
      if(/Law Society of British Columbia/i.test(t))el.dataset.lawType='bc';
      else if(/Law Society of Alberta/i.test(t))el.dataset.lawType='ab';
    }
    if(!el.dataset.lawType)return;
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(el.dataset.lawType==='bc'&&T.footer_law_soc_bc)el.textContent=T.footer_law_soc_bc;
    else if(el.dataset.lawType==='ab'&&T.footer_law_soc_ab)el.textContent=T.footer_law_soc_ab;
  });
};
var _sv=localStorage.getItem('sidhu_lang');
if(_sv&&_sv!=='en'&&_ST[_sv])window.sidhuSetLang(_sv);
})();
</script>
<script>
// ── Phase-6 translation handler ───────────────────────────────────────────────
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;
var _o6=window.sidhuSetLang;
window.sidhuSetLang=function(lang){
  _o6(lang);
  var T=_ST[lang]||_ST.en;
  function tx(el,key,html){
    if(!el)return;
    if(!el.dataset.orig)el.dataset.orig=html?el.innerHTML:el.textContent;
    if(lang==='en'){if(html)el.innerHTML=el.dataset.orig;else el.textContent=el.dataset.orig;}
    else if(T[key]){if(html)el.innerHTML=T[key];else el.textContent=T[key];}
  }
  // ── Modal ──────────────────────────────────────────────────────────────────
  tx(document.querySelector('.modal-eyebrow'),'modal_eyebrow',false);
  tx(document.querySelector('.modal-title'),'modal_title',false);
  tx(document.querySelector('.modal-sub'),'modal_sub',false);
  tx(document.querySelector('.modal-submit'),'btn_main_submit',false);
  tx(document.querySelector('.modal-note'),'form_note',false);
  tx(document.querySelector('.modal-success h3'),'modal_success_h3',false);
  tx(document.querySelector('.modal-success p'),'modal_success_p',false);
  // Modal labels
  var mlMap={'full name':'label_name','phone number':'label_phone','type of case':'label_case','brief description':'label_message','brief description (optional)':'label_message'};
  document.querySelectorAll('.modal-label').forEach(function(el){
    var k=mlMap[(el.dataset.orig||el.textContent).trim().toLowerCase()];
    if(!k)return;
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(T[k])el.textContent=T[k];
  });
  // Modal input placeholders (name + textarea; skip phone — city-specific)
  document.querySelectorAll('#caseModal input[name="name"],#modalForm input[name="name"]').forEach(function(i){
    if(!i.dataset.orig)i.dataset.orig=i.placeholder;
    i.placeholder=lang==='en'?i.dataset.orig:(T.ph_name||i.dataset.orig);
  });
  document.querySelectorAll('#caseModal textarea,#modalForm textarea').forEach(function(i){
    if(!i.dataset.orig)i.dataset.orig=i.placeholder;
    i.placeholder=lang==='en'?i.dataset.orig:(T.ph_message||i.dataset.orig);
  });
  // ── .btn-gold CTA buttons (not phone links) ────────────────────────────────
  document.querySelectorAll('.btn-gold[data-modal],.btn-gold[href="#"]').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent.trim();
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(T.btn_get_review)el.textContent=T.btn_get_review;
  });
  // ── "Brief Description" label (no "(optional)") ────────────────────────────
  document.querySelectorAll('.form-group label').forEach(function(el){
    if((el.dataset.orig||el.textContent).trim().toLowerCase()==='brief description'){
      if(!el.dataset.orig)el.dataset.orig=el.textContent;
      if(lang==='en')el.textContent=el.dataset.orig;
      else if(T.label_message)el.textContent=T.label_message;
    }
  });
  // ── Contact section inline note (classless <p> with "confidential") ────────
  document.querySelectorAll('#contact p:not([class]),[id="contact"] p:not([class])').forEach(function(el){
    var t=(el.textContent||'').toLowerCase();
    if(t.indexOf('confidential')<0&&t.indexOf('obligation')<0)return;
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en')el.textContent=el.dataset.orig;
    else if(T.form_note)el.textContent=T.form_note;
  });
  // ── Quote attribution ──────────────────────────────────────────────────────
  tx(document.querySelector('.quote-attr'),'quote_attr',false);
};
var _sv6=localStorage.getItem('sidhu_lang');
if(_sv6&&_sv6!=='en'&&_ST[_sv6])window.sidhuSetLang(_sv6);
})();
</script>
<script>
// ── Phase-8 translation handler (BC why-headings + accident steps) ────────────
(function(){
if(typeof _ST==='undefined'||typeof window._sidhuCity==='undefined')return;
function ac(s){return(s||'').replace(/\{city\}/g,window._sidhuCity);}
