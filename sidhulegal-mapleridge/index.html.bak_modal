if(_ST['fr'])_ST['fr']['rights_r1']='<strong>Couverture complète des frais médicaux</strong> incluant les traitements continus, la physiothérapie et les soins spécialisés.';
if(_ST['fr'])_ST['fr']['rights_r2']='<strong>Remplacement des salaires perdus</strong> pour chaque jour où vous n’avez pas pu travailler en raison de vos blessures.';
