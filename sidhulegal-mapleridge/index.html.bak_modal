if(_ST['es'])_ST['es']['why_speak_desc']='Asesoría legal en inglés, punjabi e hindi. Sin barreras idiomáticas entre usted y la justicia que merece.';
if(_ST['es'])_ST['es']['lang_sub_para']='Sidhu Legal realiza consultas y actualizaciones en inglés, punjabi e hindi para que nada se pierda y usted esté completamente informado en cada etapa.';
