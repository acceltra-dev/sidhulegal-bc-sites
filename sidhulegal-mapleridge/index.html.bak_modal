<!-- CASE VALUE CALCULATOR (BC) -->
<style>
.vf-est{background:#0d1b2a;color:#fff;padding:3.4rem 2.5rem}
.vf-wrap{max-width:1080px;margin:0 auto}
.vf-est .vf-eyebrow{color:#c9a040;font-weight:700;letter-spacing:.1em;text-transform:uppercase;font-size:.78rem}
.vf-est h2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.9rem,4vw,2.8rem);margin:.4rem 0 .5rem;color:#fff}
.vf-est .vf-sub{color:#aab6c4;max-width:640px;margin-bottom:1.6rem}
.vf-est-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:2.5rem;align-items:start}
.vf-field{margin-bottom:1rem}
.vf-field label{display:block;font-size:.82rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#c9a040;margin-bottom:.5rem}
.vf-field select,.vf-field input{width:100%;padding:.85rem 1rem;border-radius:10px;border:1px solid rgba(201,160,64,.3);background:#16263a;color:#fff;font:inherit}
.vf-sev{display:flex;gap:.5rem;flex-wrap:wrap}
.vf-sev label{flex:1;min-width:90px;text-align:center;background:#16263a;border:1px solid rgba(201,160,64,.3);border-radius:10px;padding:.7rem;cursor:pointer;font-size:.9rem;color:#cfd6e0;font-weight:600;transition:.15s}
.vf-sev input{position:absolute;opacity:0}
.vf-sev label:has(input:checked){background:#c9a040;color:#0d1b2a;border-color:#c9a040}
.vf-est-result{background:linear-gradient(160deg,#16263a,#0d1b2a);border:1px solid rgba(201,160,64,.35);border-radius:16px;padding:2rem;text-align:center}
.vf-est-result .vf-rlabel{font-size:.8rem;text-transform:uppercase;letter-spacing:.08em;color:#aab6c4}
.vf-range{font-family:'Playfair Display',Georgia,serif;font-size:clamp(1.8rem,4vw,2.6rem);color:#c9a040;margin:.5rem 0;font-weight:800}
.vf-est-result .vf-disc{font-size:.72rem;color:#8a98a8;line-height:1.6;margin-top:1rem}
.vf-est-result .vf-cta{display:inline-block;margin-top:1.2rem;background:#c9a040;color:#0d1b2a;padding:.85rem 1.6rem;border-radius:40px;font-weight:700;text-decoration:none}
.vf-est-result .vf-cta:hover{background:#d4ac4a}
@media(max-width:760px){.vf-est-grid{grid-template-columns:1fr}}
</style>
<section class="vf-est" id="estimate">
  <div class="vf-wrap">
    <span class="vf-eyebrow">Free Tool</span>
    <h2>Estimate the Value of Your Injury Claim</h2>
    <p class="vf-sub">Answer a few quick questions for a rough, instant illustration of a potential injury claim range. In BC, auto injuries are handled through ICBC's Enhanced Care system, so real amounts vary case by case. For an honest assessment, talk to Shawn Sidhu for free.</p>
    <div class="vf-est-grid">
      <div>
        <div class="vf-field"><label>Type of injury</label>
          <select id="vf-injury">
            <option value="25000">Soft tissue / whiplash</option>
            <option value="55000">Broken bones / fractures</option>
            <option value="110000">Chronic pain or nerve damage</option>
            <option value="180000">Serious or multiple injuries</option>
            <option value="380000">Brain or spinal cord injury</option>
            <option value="600000">Catastrophic (paralysis, amputation, burns)</option>
            <option value="750000">Wrongful death</option>
            <option value="call">Other or not sure</option>
          </select></div>
        <div class="vf-field"><label>Severity</label>
          <div class="vf-sev">
            <label><input type="radio" name="vf-sev" value="0.6"><span>Minor</span></label>
            <label><input type="radio" name="vf-sev" value="1" checked><span>Moderate</span></label>
            <label><input type="radio" name="vf-sev" value="1.8"><span>Severe</span></label>
          </div></div>
        <div class="vf-field"><label>Weeks unable to work</label>
          <input type="number" id="vf-weeks" min="0" max="520" placeholder="e.g. 8" value="0"></div>
        <div class="vf-field"><label>Your weekly income ($)</label>
          <input type="number" id="vf-wage" min="0" placeholder="e.g. 1200" value="0"></div>
      </div>
      <div class="vf-est-result" id="vf-result">
        <div id="vf-numeric">
          <div class="vf-rlabel">Estimated potential range</div>
          <div class="vf-range" id="vf-range">$0</div>
          <div class="vf-rlabel">Tap a field to update</div>
        </div>
        <div id="vf-callmsg" style="display:none">
          <div class="vf-rlabel">Your case is unique</div>
          <div class="vf-range">Let&rsquo;s talk</div>
          <p style="color:#aab6c4;font-size:.92rem;line-height:1.6;margin:.5rem 0 0">A case like yours deserves a real answer, not a calculator. Call us for a free, honest estimate of what your claim could be worth.</p>
        </div>
        <p class="vf-disc">This is a rough illustration only and <b>not</b> legal advice, a guarantee, or a prediction of any ICBC benefit or settlement. The best way to find out what your claim is really worth is a free, no-obligation case review.</p>
        <a class="vf-cta" id="vf-cta" href="#contact" onclick="event.preventDefault();var c=document.getElementById('contact');if(c)c.scrollIntoView({behavior:'smooth',block:'start'});">Get My Real Estimate &rarr;</a>
      </div>
    </div>
  </div>
</section>
<script>
(function(){
  function vfEst(){
    var sel=document.getElementById('vf-injury');
    var num=document.getElementById('vf-numeric');
    var msg=document.getElementById('vf-callmsg');
    var cta=document.getElementById('vf-cta');
    if(sel && sel.value==='call'){
      if(num)num.style.display='none';
      if(msg)msg.style.display='block';
      if(cta){cta.innerHTML='☎ Call (604) 907-3632';cta.setAttribute('href','tel:+16049073632');cta.onclick=null;}
      return;
    }
    if(num)num.style.display='';
    if(msg)msg.style.display='none';
    if(cta){cta.innerHTML='Get My Real Estimate →';cta.setAttribute('href','#contact');cta.onclick=function(e){e.preventDefault();var c=document.getElementById('contact');if(c)c.scrollIntoView({behavior:'smooth',block:'start'});};}
    var inj=+sel.value;
    var sevEl=document.querySelector('input[name="vf-sev"]:checked');
    var sev=sevEl?+sevEl.value:1;
    var weeks=+document.getElementById('vf-weeks').value||0;
    var wage=+document.getElementById('vf-wage').value||0;
    var base=inj*sev, lost=weeks*wage;
    var low=Math.max(0,Math.round((base*0.6+lost)/1000)*1000);
    var high=Math.round((base*1.45+lost*1.35)/1000)*1000;
    var r=document.getElementById('vf-range');
    if(r) r.textContent='$'+low.toLocaleString()+' – $'+high.toLocaleString();
  }
  ['vf-injury','vf-weeks','vf-wage'].forEach(function(id){var e=document.getElementById(id);if(e){e.addEventListener('input',vfEst);e.addEventListener('change',vfEst);}});
  document.querySelectorAll('input[name="vf-sev"]').forEach(function(e){e.addEventListener('change',vfEst);});
  if(document.getElementById('vf-range'))vfEst();
})();
</script>

