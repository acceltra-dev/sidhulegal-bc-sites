if(_ST['hi'])_ST['hi']['pd_car']='हम बीमा कंपनियों से लड़ते हैं ताकि आपको वह पूरा मुआवजा मिले जो आप के हकदार हैं, न कि वह जो वे देना चाहते हैं।';
if(_ST['hi'])_ST['hi']['pd_brain']='गंभीर चोटों के लिए गंभीर कानूनी प्रतिनिधित्व जरूरी है। हम मस्तिष्क, रीढ़ और अन्य गंभीर चोटों के लिए अधिकतम मुआवजा प्राप्त करते हैं।';
if(_ST['hi'])_ST['hi']['pd_slip']='संपत्ति मालिकों की कानूनी जिम्मेदारी है कि वे परिसर को सुरक्षित रखें। अगर उनकी लापरवाही से आप गिरे, तो आप मुआवजे के हकदार हो सकते हैं।';
if(_ST['hi'])_ST['hi']['pd_moto']='मोटरसाइकिल सवारों को अनोखे जोखिमों और बीमाकर्ताओं के पूर्वाग्रह का सामना करना पड़ता है। हम आपके लिए हर संभव मुआवजे के लिए लड़ते हैं।';
if(_ST['hi'])_ST['hi']['pd_death']='यदि किसी की लापरवाही से आपने प्रियजन खोया है, तो हम आपके परिवार की ओर से करुणा और दृढ़ता से पूर्ण मुआवजा प्राप्त करते हैं।';
if(_ST['hi'])_ST['hi']['pd_ltd']='बीमा कंपनियां अक्सर वैध दीर्घकालिक विकलांगता दावों को अस्वीकार कर देती हैं। हम उन फैसलों को चुनौती देते हैं और आपके अधिकारों के लिए लड़ते हैं।';
if(_ST['hi'])_ST['hi']['pd_ped']='वाहनों से टक्कर खाए पैदल यात्रियों को गंभीर चोटें आती हैं। हम चिकित्सा खर्च, आय हानि और दीर्घकालिक देखभाल के लिए पूर्ण मुआवजे के लिए लड़ते हैं।';
