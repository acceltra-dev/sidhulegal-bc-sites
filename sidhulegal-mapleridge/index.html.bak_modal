  }
  var whySec=document.querySelector('#why');
  if(!whySec)return;
  tx(whySec.querySelector('.section-sub'),'why_sub');
  var pats=[
    {r:/contingency|upfront cost|no fee unless|zero.*financial|owe us nothing/i,k:'why_p_contingency'},
    {r:/punjabi|hindi|no language|language barrier|three languages|multilingual/i,k:'why_p_languages'},
    {r:/shawn.*directly|directly.*shawn|speak.*directly|directly.*speak|talk.*directly|not.*paralegal|paralegal.*not|talk to shawn|speak.*shawn/i,k:'why_p_direct'},
    {r:/consult|fill.*form|call.*fill|review your case|explain your options/i,k:'why_p_consult'},
  ];
  whySec.querySelectorAll('.why-text p,.why-box p,.why-box-desc,.why-point>div>p').forEach(function(el){
    if(!el.dataset.orig)el.dataset.orig=el.textContent;
    if(lang==='en'){el.textContent=el.dataset.orig;return;}
    var raw=(el.dataset.orig||'').trim();
    for(var i=0;i<pats.length;i++){
      if(pats[i].r.test(raw)){if(T[pats[i].k])el.textContent=T[pats[i].k];return;}
    }
    if(T.why_p_local)el.textContent=T.why_p_local;
  });
};
var _sv9c=localStorage.getItem('sidhu_lang');
if(_sv9c&&_sv9c!=='en'&&_ST[_sv9c])window.sidhuSetLang(_sv9c);
})();
</script>
